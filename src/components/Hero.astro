---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { personal, hero } = portfolioConfig;
---

<section class="panel first" id="hero">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg bg-dot-grid">
        <!-- Ambient glow -->
        <div class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full pointer-events-none"
             style="background: radial-gradient(ellipse, rgba(255,77,0,0.06) 0%, transparent 70%);"></div>

        <div class="panel-content flex flex-col justify-center">
          <h1 class="panel-heading font-display font-extrabold tracking-[-0.04em]"
              style="font-size: clamp(3rem, 12vw, 13rem); line-height: 0.85;">
            <span class="block overflow-hidden">
              <span class="hero-line block">{personal.firstName}</span>
            </span>
            <span class="block overflow-hidden">
              <span class="hero-line block">{personal.lastName1}</span>
            </span>
            <span class="block overflow-hidden">
              <span class="hero-line block text-accent">{personal.lastName2}</span>
            </span>
          </h1>

          <div class="hero-fade mt-6 md:mt-10 flex items-center gap-4">
            <div class="h-px bg-accent w-8 md:w-12 flex-shrink-0"></div>
            <p class="font-mono text-xs md:text-sm text-muted uppercase tracking-[0.2em]">
              {hero.tagline}
            </p>
          </div>

          <p class="hero-fade mt-4 max-w-xl text-base md:text-lg text-muted leading-relaxed">
            {hero.description}
          </p>

          <div class="hero-fade mt-8 font-mono text-[10px] text-muted/40 uppercase tracking-[0.3em]">
            Scroll to explore
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
