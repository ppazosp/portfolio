---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { personal, hero } = portfolioConfig;
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden">
  <!-- Three.js Canvas Background -->
  <canvas id="three-canvas" class="absolute inset-0 w-full h-full" style="pointer-events: none; z-index: 1;"></canvas>

  <!-- Dot grid -->
  <div class="absolute inset-0 bg-dot-grid" style="z-index: 2;"></div>

  <!-- Ambient glow -->
  <div
    class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] md:w-[900px] md:h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(0,245,212,0.05) 0%, transparent 70%); z-index: 2;"
  ></div>

  <!-- Content -->
  <div class="hero-parallax relative pt-24 max-w-[1400px] mx-auto px-6 md:px-12 w-full" style="z-index: 3;">
    <!-- Name -->
    <h1
      class="font-display font-extrabold tracking-[-0.04em]"
      style="font-size: clamp(3.5rem, 13vw, 14rem); line-height: 0.85;"
    >
      <span class="block overflow-hidden">
        <span class="hero-line block">{personal.firstName}</span>
      </span>
      <span class="block overflow-hidden">
        <span class="hero-line block">{personal.lastName1}</span>
      </span>
      <span class="block overflow-hidden">
        <span class="hero-line block text-accent">{personal.lastName2}</span>
      </span>
    </h1>

    <!-- Tagline -->
    <div class="hero-fade mt-8 md:mt-12 flex items-center gap-4">
      <div class="h-px bg-accent w-8 md:w-12 flex-shrink-0"></div>
      <p class="font-mono text-xs md:text-sm text-muted uppercase tracking-[0.2em]">
        {hero.tagline}
      </p>
    </div>

    <!-- Description -->
    <p class="hero-fade mt-6 max-w-xl text-base md:text-lg text-muted leading-relaxed">
      {hero.description}
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-indicator hero-fade" style="z-index: 3;">
    <div class="flex flex-col items-center gap-2">
      <span class="font-mono text-[10px] text-muted/40 uppercase tracking-[0.3em]">Scroll</span>
      <div class="w-px h-14 bg-gradient-to-b from-accent/30 to-transparent"></div>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Three.js Background ──
  const canvas = document.getElementById('three-canvas') as HTMLCanvasElement;
  if (canvas) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Outer wireframe icosahedron
    const outerGeo = new THREE.IcosahedronGeometry(3, 1);
    const outerMat = new THREE.MeshBasicMaterial({
      color: 0x00F5D4,
      wireframe: true,
      transparent: true,
      opacity: 0.08
    });
    const outerSphere = new THREE.Mesh(outerGeo, outerMat);

    // Inner wireframe icosahedron
    const innerGeo = new THREE.IcosahedronGeometry(2, 2);
    const innerMat = new THREE.MeshBasicMaterial({
      color: 0x00F5D4,
      wireframe: true,
      transparent: true,
      opacity: 0.04
    });
    const innerSphere = new THREE.Mesh(innerGeo, innerMat);

    // Particles
    const particleCount = 300;
    const particlePositions = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount * 3; i++) {
      particlePositions[i] = (Math.random() - 0.5) * 15;
    }
    const particleGeo = new THREE.BufferGeometry();
    particleGeo.setAttribute('position', new THREE.BufferAttribute(particlePositions, 3));
    const particleMat = new THREE.PointsMaterial({
      color: 0x00F5D4,
      size: 0.015,
      transparent: true,
      opacity: 0.5,
      blending: THREE.AdditiveBlending
    });
    const particles = new THREE.Points(particleGeo, particleMat);

    // Small orbiting sphere
    const orbitGeo = new THREE.OctahedronGeometry(0.5, 0);
    const orbitMat = new THREE.MeshBasicMaterial({
      color: 0xFF4D00,
      wireframe: true,
      transparent: true,
      opacity: 0.15
    });
    const orbitSphere = new THREE.Mesh(orbitGeo, orbitMat);
    orbitSphere.position.set(4.5, 1, 0);

    scene.add(outerSphere, innerSphere, particles, orbitSphere);
    camera.position.z = 7;
    camera.position.x = 2;

    // Mouse tracking
    let mouseX = 0, mouseY = 0;
    window.addEventListener('mousemove', (e) => {
      mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
      mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
    });

    // Scroll progress
    let scrollProgress = 0;
    ScrollTrigger.create({
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      onUpdate: (self) => {
        scrollProgress = self.progress;
      }
    });

    // Resize
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // Animation loop
    let time = 0;
    function animate() {
      requestAnimationFrame(animate);
      time += 0.005;

      outerSphere.rotation.x += 0.002;
      outerSphere.rotation.y += 0.003;
      innerSphere.rotation.x -= 0.003;
      innerSphere.rotation.y -= 0.002;

      // Mouse influence
      outerSphere.rotation.x += (mouseY * 0.1 - outerSphere.rotation.x) * 0.02;
      outerSphere.rotation.y += (mouseX * 0.1 - outerSphere.rotation.y) * 0.02;

      // Orbiting sphere
      orbitSphere.position.x = Math.cos(time * 1.5) * 4.5;
      orbitSphere.position.z = Math.sin(time * 1.5) * 4.5;
      orbitSphere.position.y = Math.sin(time * 2) * 1;
      orbitSphere.rotation.x += 0.02;
      orbitSphere.rotation.y += 0.03;

      // Particles slow rotation
      particles.rotation.y += 0.0005;
      particles.rotation.x += 0.0002;

      // Scroll-driven effects
      const s = 1 + scrollProgress * 3;
      outerSphere.scale.setScalar(s);
      innerSphere.scale.setScalar(s * 0.9);
      outerMat.opacity = 0.08 * (1 - scrollProgress);
      innerMat.opacity = 0.04 * (1 - scrollProgress);
      particleMat.opacity = 0.5 * (1 - scrollProgress);
      orbitMat.opacity = 0.15 * (1 - scrollProgress);

      // Vertex distortion on outer sphere
      const positions = outerGeo.attributes.position;
      const original = outerGeo.getAttribute('position').array;
      for (let i = 0; i < positions.count; i++) {
        const ix = i * 3;
        const ox = original[ix], oy = original[ix + 1], oz = original[ix + 2];
        const noise = Math.sin(ox * 2 + time * 2) * Math.cos(oy * 2 + time * 3) * 0.08;
        positions.setXYZ(i, ox + ox * noise, oy + oy * noise, oz + oz * noise);
      }
      positions.needsUpdate = true;

      renderer.render(scene, camera);
    }
    animate();
  }

  // ── GSAP Hero Animations ──

  // Name lines reveal
  gsap.to('.hero-line', {
    y: 0,
    duration: 1.4,
    stagger: 0.12,
    ease: "power4.out",
    delay: 1.2
  });

  // Fade in elements
  gsap.to('.hero-fade', {
    autoAlpha: 1,
    y: 0,
    duration: 1,
    stagger: 0.15,
    delay: 2,
    ease: "power3.out"
  });

  // Scroll indicator float
  gsap.to('.scroll-indicator', {
    y: 8,
    duration: 1.8,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
    delay: 3.5
  });

  // Hero parallax on scroll
  gsap.to('.hero-parallax', {
    y: -150,
    autoAlpha: 0.1,
    ease: "none",
    scrollTrigger: {
      trigger: '#hero',
      start: "top top",
      end: "bottom top",
      scrub: true
    }
  });
</script>
