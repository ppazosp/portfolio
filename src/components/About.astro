---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { about, personal } = portfolioConfig;

const line1 = about.headline[0].toUpperCase();
const accentLine = about.headline[1].toUpperCase();
const line3 = about.headline[2].toUpperCase();
---

<section class="panel" id="about">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">

        <div class="panel-content h-full flex flex-col">
          <div class="section-label mb-2 md:mb-3">
            <span>{locale === 'es' ? 'Sobre mi' : 'About'}</span>
          </div>

          <div class="flex-1 flex flex-col justify-center md:justify-center">
            <!-- Masked headline wipe -->
            <div class="panel-heading mb-5 md:mb-8">
              <div class="overflow-hidden">
                <span class="about-line block font-display font-extrabold tracking-[-0.04em]"
                      style="font-size: clamp(1.8rem, 7.5vw, 7rem); line-height: 0.9;">
                  {line1}
                </span>
              </div>
              <div class="overflow-hidden">
                <span class="about-line block font-display font-extrabold tracking-[-0.04em] text-accent"
                      style="font-size: clamp(1.8rem, 7.5vw, 7rem); line-height: 0.9;">
                  {accentLine}
                </span>
              </div>
              <div class="overflow-hidden">
                <span class="about-line block font-display font-extrabold tracking-[-0.04em]"
                      style="font-size: clamp(1.8rem, 7.5vw, 7rem); line-height: 0.9;">
                  {line3}
                </span>
              </div>
            </div>

            <!-- Decorative divider -->
            <div class="about-fade flex items-center gap-3 mb-4 md:mb-14">
              <div class="h-px w-8 md:w-12" style="background: var(--color-accent); opacity: 0.4;"></div>
              <div class="w-1.5 h-1.5 rounded-full" style="background: var(--color-accent); opacity: 0.6;"></div>
              <div class="h-px w-8 md:w-12" style="background: var(--color-accent); opacity: 0.4;"></div>
            </div>

            <!-- Content grid -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-10">
              <!-- Stats with accent line -->
              <div class="lg:col-span-5 relative lg:pl-8">
                <div class="about-accent-line hidden lg:block absolute left-0 top-0 w-px h-full origin-top"
                     style="background: linear-gradient(to bottom, var(--color-accent), transparent);"></div>
                <div class="grid grid-cols-2 gap-x-6 md:gap-x-12 gap-y-3 md:gap-y-8">
                  {about.stats.map((stat) => (
                    <div class="about-stat">
                      <span class="block font-display text-4xl md:text-5xl lg:text-6xl font-bold text-accent about-stat-value"
                            data-value={stat.value}
                            data-suffix={stat.suffix}>
                        0{stat.suffix}
                      </span>
                      <div class="h-px w-full mt-2 mb-1 md:mt-3 md:mb-2" style="background: linear-gradient(to right, var(--color-accent), transparent); opacity: 0.3;"></div>
                      <span class="font-mono text-[10px] md:text-xs text-muted uppercase tracking-[0.15em]">
                        {stat.label}
                      </span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Description -->
              <div class="lg:col-span-7 flex flex-col justify-between gap-4 md:gap-6">
                <p class="about-fade text-sm md:text-lg text-foreground/80 leading-relaxed max-w-lg">
                  {about.description}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-line {
    transform: translateY(110%);
    will-change: transform;
  }
  .about-fade {
    opacity: 0;
    transform: translateY(20px);
    will-change: transform, opacity;
  }
  .about-stat {
    opacity: 0;
    transform: translateY(25px);
    will-change: transform, opacity;
  }
  .about-accent-line {
    transform: scaleY(0);
    will-change: transform;
  }
</style>

<script>
  import gsap from 'gsap';

  const panel = document.getElementById('about');
  if (panel) {
    let revealed = false;

    function revealAbout() {
      if (revealed) return;
      revealed = true;

      const tl = gsap.timeline({ delay: 0.5 });

      // Masked headline wipe
      tl.to('.about-line', {
        y: 0,
        duration: 1,
        stagger: 0.12,
        ease: "power4.out"
      });

      // Divider + tagline + description + links
      tl.to('.about-fade', {
        autoAlpha: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.1,
        ease: "power3.out"
      }, "-=0.5");

      // Vertical accent line draws down
      tl.to('.about-accent-line', {
        scaleY: 1,
        duration: 1.2,
        ease: "power2.inOut"
      }, "-=0.6");

      // Stats entrance
      tl.to('.about-stat', {
        autoAlpha: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: "power3.out"
      }, "-=1.0");

      // Stat counting
      document.querySelectorAll('.about-stat-value').forEach(el => {
        const target = parseInt((el as HTMLElement).dataset.value || '0');
        const suffix = (el as HTMLElement).dataset.suffix || '';
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2,
          delay: 1,
          ease: "power2.out",
          snap: { val: 1 },
          onUpdate: () => { el.textContent = Math.round(obj.val) + suffix; }
        });
      });
    }

    const observer = new MutationObserver(() => {
      if (panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
        revealAbout();
        observer.disconnect();
      }
    });
    observer.observe(panel, { attributes: true, attributeFilter: ['style'] });

    if (panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
      setTimeout(revealAbout, 600);
    }
  }
</script>
