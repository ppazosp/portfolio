---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { contact, personal } = portfolioConfig;

const headlineWords = contact.headline.split(' ');
---

<section id="contact" class="py-32 md:py-48 relative overflow-hidden">
  <!-- Ambient glow -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(0,245,212,0.05) 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="section-label">
      <span>{locale === 'es' ? 'Contacto' : 'Contact'}</span>
    </div>

    <div class="text-center max-w-3xl mx-auto">
      <!-- Headline with word split -->
      <h2 class="contact-headline font-display text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-10 leading-[0.95]">
        {headlineWords.map((word, i) => (
          <span class="inline-block overflow-hidden mr-[0.25em]">
            <span class="contact-word inline-block" style={`--i: ${i}`}>
              {word}
            </span>
          </span>
        ))}
      </h2>

      <!-- Email with scramble effect -->
      <a
        href={`mailto:${personal.email}`}
        class="contact-reveal magnetic-btn inline-block font-mono text-sm md:text-lg text-accent hover:text-foreground transition-colors border-b border-accent/30 hover:border-foreground pb-1 mb-14"
        data-scramble={personal.email}
      >
        {personal.email}
      </a>

      <!-- Links row -->
      <div class="contact-reveal flex items-center justify-center gap-6 md:gap-8 flex-wrap">
        <a
          href={`https://github.com/${personal.github}`}
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic-btn font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors px-3 py-2"
        >
          GitHub
        </a>
        <span class="text-border select-none">|</span>
        <a
          href={`https://linkedin.com/in/${personal.linkedin}`}
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic-btn font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors px-3 py-2"
        >
          LinkedIn
        </a>
        <span class="text-border select-none">|</span>
        <a
          href={contact.cv}
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic-btn font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors px-3 py-2"
        >
          {locale === 'es' ? 'Curriculum' : 'Resume'}
        </a>
        <span class="text-border select-none">|</span>
        <a
          href={personal.company.url}
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic-btn font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors px-3 py-2"
        >
          {personal.company.name}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Word-by-word headline reveal
  gsap.from('.contact-word', {
    y: '120%',
    rotationX: -30,
    duration: 1.2,
    stagger: 0.08,
    ease: "power4.out",
    scrollTrigger: {
      trigger: '.contact-headline',
      start: "top 80%"
    }
  });

  // Fade reveals
  gsap.from('.contact-reveal', {
    y: 40,
    autoAlpha: 0,
    duration: 1,
    stagger: 0.15,
    ease: "power3.out",
    scrollTrigger: {
      trigger: '.contact-reveal',
      start: "top 85%"
    }
  });

  // Text scramble effect on email hover
  const scrambleEl = document.querySelector('[data-scramble]') as HTMLElement;
  if (scrambleEl) {
    const originalText = scrambleEl.dataset.scramble || '';
    const chars = '!@#$%^&*()_+-={}[]|:;<>?/~`';

    scrambleEl.addEventListener('mouseenter', () => {
      let iteration = 0;
      const interval = setInterval(() => {
        scrambleEl.textContent = originalText
          .split('')
          .map((char, i) => {
            if (i < iteration) return originalText[i];
            return chars[Math.floor(Math.random() * chars.length)];
          })
          .join('');

        if (iteration >= originalText.length) {
          clearInterval(interval);
        }
        iteration += 1 / 2;
      }, 25);
    });

    scrambleEl.addEventListener('mouseleave', () => {
      scrambleEl.textContent = originalText;
    });
  }

  // Magnetic buttons
  document.querySelectorAll('#contact .magnetic-btn').forEach(btn => {
    const el = btn as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      gsap.to(el, { x: x * 0.2, y: y * 0.2, duration: 0.3 });
    });
    el.addEventListener('mouseleave', () => {
      gsap.to(el, { x: 0, y: 0, duration: 0.6, ease: "elastic.out(1, 0.3)" });
    });
  });
</script>
