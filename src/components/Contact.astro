---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { contact, personal, footer } = portfolioConfig;

const links = [
  { label: "GitHub", href: `https://github.com/${personal.github}` },
  { label: "LinkedIn", href: `https://linkedin.com/in/${personal.linkedin}` },
  { label: locale === 'es' ? 'Curriculum' : 'Resume', href: contact.cv },
  { label: personal.company.name, href: personal.company.url },
];
---

<section class="panel" id="contact">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <!-- Ambient glow -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full pointer-events-none"
             style="background: radial-gradient(ellipse, rgba(255,77,0,0.05) 0%, transparent 70%);"></div>

        <div class="panel-content flex flex-col items-center justify-center text-center">
          <div class="section-label w-full mb-8">
            <span>{locale === 'es' ? 'Contacto' : 'Contact'}</span>
          </div>

          <h2 class="panel-heading font-display text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-8 leading-[0.95]">
            {contact.headline}
          </h2>

          <!-- Email with scramble -->
          <a href={`mailto:${personal.email}`}
             class="inline-block font-mono text-sm md:text-lg text-accent hover:text-foreground transition-colors border-b border-accent/30 hover:border-foreground pb-1 mb-12"
             data-scramble={personal.email}>
            {personal.email}
          </a>

          <!-- Rolling text links -->
          <div class="flex items-center justify-center gap-6 md:gap-8 flex-wrap">
            {links.map((link, i) => (
              <Fragment>
                {i > 0 && <span class="text-border select-none">|</span>}
                <a href={link.href} target="_blank" rel="noopener noreferrer"
                   class="roll-link font-mono text-xs uppercase tracking-[0.15em]">
                  <span class="roll-text">
                    <span class="roll-top text-muted">{link.label}</span>
                    <span class="roll-bottom text-accent" aria-hidden="true">{link.label}</span>
                  </span>
                </a>
              </Fragment>
            ))}
          </div>

          <!-- Footer info -->
          <div class="absolute bottom-6 left-0 right-0 px-12 flex items-center justify-between">
            <span class="font-mono text-[10px] text-muted/40">{footer.location}</span>
            <a href={footer.sourceCode.url} target="_blank" rel="noopener noreferrer"
               class="font-mono text-[10px] text-muted/40 hover:text-accent transition-colors">{footer.sourceCode.text}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .roll-link {
    display: inline-block;
    overflow: hidden;
    height: 1.4em;
    line-height: 1.4em;
    cursor: pointer;
  }

  .roll-text {
    display: flex;
    flex-direction: column;
    transition: transform 0.35s cubic-bezier(0.76, 0, 0.24, 1);
  }

  .roll-link:hover .roll-text {
    transform: translateY(-50%);
  }

  .roll-top,
  .roll-bottom {
    display: block;
    height: 1.4em;
    line-height: 1.4em;
  }
</style>

<script>
  // Text scramble on email hover
  const scrambleEl = document.querySelector('[data-scramble]') as HTMLElement;
  if (scrambleEl) {
    const originalText = scrambleEl.dataset.scramble || '';
    const chars = '!@#$%^&*()_+-={}[]|:;<>?/~`';
    scrambleEl.addEventListener('mouseenter', () => {
      let iteration = 0;
      const interval = setInterval(() => {
        scrambleEl.textContent = originalText.split('').map((char, i) => {
          if (i < iteration) return originalText[i];
          return chars[Math.floor(Math.random() * chars.length)];
        }).join('');
        if (iteration >= originalText.length) clearInterval(interval);
        iteration += 0.5;
      }, 25);
    });
    scrambleEl.addEventListener('mouseleave', () => { scrambleEl.textContent = originalText; });
  }
</script>
