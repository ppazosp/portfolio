---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { contact, personal } = portfolioConfig;
---

<section id="contact" class="py-32 md:py-40 relative overflow-hidden">
  <!-- Ambient glow -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(0,245,212,0.04) 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 max-w-[1400px] mx-auto px-6 md:px-12">
    <!-- Section label -->
    <div class="section-label">
      <span>{locale === 'es' ? 'Contacto' : 'Contact'}</span>
    </div>

    <div class="text-center max-w-2xl mx-auto">
      <!-- Headline -->
      <h2 class="contact-reveal font-display text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-8">
        {contact.headline}
      </h2>

      <!-- Email (large, clickable) -->
      <a
        href={`mailto:${personal.email}`}
        class="contact-reveal inline-block font-mono text-sm md:text-base text-accent hover:text-foreground transition-colors border-b border-accent/30 hover:border-foreground pb-1 mb-12"
      >
        {personal.email}
      </a>

      <!-- Links row -->
      <div class="contact-reveal flex items-center justify-center gap-6 md:gap-8 flex-wrap">
        <a
          href={`https://github.com/${personal.github}`}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors"
        >
          GitHub
        </a>
        <span class="text-border">|</span>
        <a
          href={`https://linkedin.com/in/${personal.linkedin}`}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors"
        >
          LinkedIn
        </a>
        <span class="text-border">|</span>
        <a
          href={contact.cv}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors"
        >
          {locale === 'es' ? 'Curriculum' : 'Resume'}
        </a>
        <span class="text-border">|</span>
        <a
          href={personal.company.url}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors"
        >
          {personal.company.name}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.contact-reveal', {
    y: 50,
    autoAlpha: 0,
    duration: 1,
    stagger: 0.15,
    ease: "power3.out",
    scrollTrigger: {
      trigger: '#contact',
      start: "top 75%"
    }
  });
</script>
