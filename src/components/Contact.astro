---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { contact, personal, footer } = portfolioConfig;

const words = contact.headline.split(' ');
const line1 = words.slice(0, -1).join(' ').toUpperCase();
const line2 = words[words.length - 1].toUpperCase();

const links = [
  { label: "GitHub", href: `https://github.com/${personal.github}` },
  { label: "LinkedIn", href: `https://linkedin.com/in/${personal.linkedin}` },
  { label: locale === 'es' ? 'Curriculum' : 'Resume', href: contact.cv },
  { label: personal.company.name, href: personal.company.url },
];
---

<section class="panel" id="contact">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <!-- Layered ambient glows -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] rounded-full pointer-events-none"
             style="background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 7%, transparent) 0%, transparent 70%);"></div>
        <div class="absolute top-1/4 left-1/4 w-[500px] h-[400px] rounded-full pointer-events-none"
             style="background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 3%, transparent) 0%, transparent 70%);"></div>

        <div class="panel-content h-full flex flex-col text-center">
          <div class="section-label w-full mb-2 md:mb-3">
            <span>{locale === 'es' ? 'Contacto' : 'Contact'}</span>
          </div>

          <div class="flex-1 flex flex-col items-center justify-center">
            <!-- Masked headline wipe -->
            <div class="panel-heading mb-5 md:mb-8">
              <div class="overflow-hidden">
                <span class="contact-line block font-display font-extrabold tracking-[-0.04em]"
                      style="font-size: clamp(2.4rem, 10vw, 8rem); line-height: 0.9;">
                  {line1}
                </span>
              </div>
              <div class="overflow-hidden">
                <span class="contact-line block font-display font-extrabold tracking-[-0.04em] text-accent"
                      style="font-size: clamp(2.4rem, 10vw, 8rem); line-height: 0.9;">
                  {line2}
                </span>
              </div>
            </div>

            <!-- Expanding decorative dividers -->
            <div class="flex items-center justify-center gap-3 mb-6 md:mb-10">
              <div class="contact-divider h-px w-8 md:w-16 origin-right" style="background: var(--color-accent); opacity: 0.4;"></div>
              <div class="contact-dot w-1.5 h-1.5 rounded-full" style="background: var(--color-accent);"></div>
              <div class="contact-divider h-px w-8 md:w-16 origin-left" style="background: var(--color-accent); opacity: 0.4;"></div>
            </div>

            <!-- Email -->
            <a href={`mailto:${personal.email}`}
               class="contact-fade inline-block font-mono text-sm md:text-lg text-accent hover:text-foreground transition-colors border-b border-accent/30 hover:border-foreground pb-1 mb-8 md:mb-12"
               data-scramble={personal.email}>
              {personal.email}
            </a>

            <!-- Character wave links -->
            <div class="flex items-center justify-center gap-5 md:gap-8 flex-wrap">
              {links.map((link, i) => (
                <Fragment>
                  {i > 0 && <span class="contact-fade text-border select-none hidden md:inline">|</span>}
                  <a href={link.href} target="_blank" rel="noopener noreferrer"
                     class="contact-fade contact-wave-link font-mono text-xs uppercase tracking-[0.15em] text-muted py-1">
                    {link.label.split('').map((char) => (
                      <span class="wave-char inline-block">{char === ' ' ? '\u00A0' : char}</span>
                    ))}
                  </a>
                </Fragment>
              ))}
            </div>
          </div>

          <div class="absolute bottom-3 md:bottom-6 left-0 right-0 px-5 md:px-12 flex items-center justify-between">
            <span class="font-mono text-[10px] text-muted/40">{footer.location}</span>
            <a href={footer.sourceCode.url} target="_blank" rel="noopener noreferrer"
               class="font-mono text-[10px] text-muted/40 hover:text-accent transition-colors">{footer.sourceCode.text}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-line {
    transform: translateY(110%);
    will-change: transform;
  }
  .contact-fade {
    opacity: 0;
    transform: translateY(15px);
    will-change: transform, opacity;
  }
  .contact-divider {
    transform: scaleX(0);
    will-change: transform;
  }
  .contact-dot {
    opacity: 0;
    will-change: opacity;
  }
</style>

<script>
  import gsap from 'gsap';

  const panel = document.getElementById('contact');
  if (panel) {
    let revealed = false;

    function revealContact() {
      if (revealed) return;
      revealed = true;

      const tl = gsap.timeline({ delay: 0.5 });

      // Masked headline wipe
      tl.to('.contact-line', {
        y: 0,
        duration: 1,
        stagger: 0.12,
        ease: "power4.out"
      });

      // Dot appears
      tl.to('.contact-dot', {
        opacity: 0.6,
        duration: 0.3,
        ease: "power2.out"
      }, "-=0.4");

      // Dividers expand from center
      tl.to('.contact-divider', {
        scaleX: 1,
        duration: 0.6,
        stagger: 0.05,
        ease: "power2.inOut"
      }, "-=0.2");

      // Email + links cascade
      tl.to('.contact-fade', {
        autoAlpha: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.06,
        ease: "power3.out"
      }, "-=0.3");
    }

    const observer = new MutationObserver(() => {
      if (panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
        revealContact();
        observer.disconnect();
      }
    });
    observer.observe(panel, { attributes: true, attributeFilter: ['style'] });

    if (panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
      setTimeout(revealContact, 600);
    }
  }

  // Text scramble on email hover
  const scrambleEl = document.querySelector('[data-scramble]') as HTMLElement;
  if (scrambleEl) {
    const originalText = scrambleEl.dataset.scramble || '';
    const chars = '!@#$%^&*()_+-={}[]|:;<>?/~`';
    scrambleEl.addEventListener('mouseenter', () => {
      let iteration = 0;
      const interval = setInterval(() => {
        scrambleEl.textContent = originalText.split('').map((char, i) => {
          if (i < iteration) return originalText[i];
          return chars[Math.floor(Math.random() * chars.length)];
        }).join('');
        if (iteration >= originalText.length) clearInterval(interval);
        iteration += 0.5;
      }, 25);
    });
    scrambleEl.addEventListener('mouseleave', () => { scrambleEl.textContent = originalText; });
  }

  // Character wave on link hover
  document.querySelectorAll('.contact-wave-link').forEach(link => {
    const chars = link.querySelectorAll('.wave-char');
    link.addEventListener('mouseenter', () => {
      gsap.to(chars, {
        y: -4,
        color: getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim(),
        stagger: { each: 0.025, from: "start" },
        duration: 0.2,
        ease: "power2.out"
      });
    });
    link.addEventListener('mouseleave', () => {
      gsap.to(chars, {
        y: 0,
        color: '',
        stagger: { each: 0.02, from: "end" },
        duration: 0.3,
        ease: "power2.inOut",
        clearProps: "color"
      });
    });
  });
</script>
