---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const altHref = locale === 'en' ? '/es/' : '/';
const altLabel = locale === 'en' ? 'ES' : 'EN';
---

<header class="header-nav fixed top-0 left-0 right-0 z-50">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
    <a href={locale === 'es' ? '/es/' : '/'} class="font-display text-lg font-bold tracking-tight text-foreground hover:text-accent transition-colors" data-panel="0">
      {portfolioConfig.navigation.brand}
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {portfolioConfig.navigation.links.map((link, i) => (
        <a
          href={link.href}
          data-panel={i + 1}
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted hover:text-foreground transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href={altHref}
        class="ml-2 font-mono text-xs uppercase tracking-[0.15em] text-muted/50 hover:text-accent transition-colors border-l border-border pl-6"
      >
        {altLabel}
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 w-7 h-7 items-center justify-center"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-px bg-foreground transition-transform origin-center" id="bar1"></span>
      <span class="block w-5 h-px bg-foreground transition-opacity" id="bar2"></span>
      <span class="block w-5 h-px bg-foreground transition-transform origin-center" id="bar3"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-background/95 backdrop-blur-md">
    <div class="max-w-[1400px] mx-auto px-6 py-6 flex flex-col gap-4">
      {portfolioConfig.navigation.links.map((link, i) => (
        <a
          href={link.href}
          data-panel={i + 1}
          class="font-mono text-sm text-muted hover:text-foreground transition-colors mobile-nav-link"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-2 border-t border-border">
        <a href={altHref} class="font-mono text-sm text-muted/50 hover:text-accent transition-colors">
          {altLabel}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  import gsap from 'gsap';

  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let menuOpen = false;

  mobileBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu?.classList.toggle('hidden', !menuOpen);
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');
    if (menuOpen) {
      gsap.to(bar1, { rotation: 45, y: 4, duration: 0.25 });
      gsap.to(bar2, { autoAlpha: 0, duration: 0.15 });
      gsap.to(bar3, { rotation: -45, y: -4, duration: 0.25 });
    } else {
      gsap.to(bar1, { rotation: 0, y: 0, duration: 0.25 });
      gsap.to(bar2, { autoAlpha: 1, duration: 0.15 });
      gsap.to(bar3, { rotation: 0, y: 0, duration: 0.25 });
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu?.classList.add('hidden');
      gsap.to('#bar1', { rotation: 0, y: 0, duration: 0.25 });
      gsap.to('#bar2', { autoAlpha: 1, duration: 0.15 });
      gsap.to('#bar3', { rotation: 0, y: 0, duration: 0.25 });
    });
  });
</script>
