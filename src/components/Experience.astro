---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { experience } = portfolioConfig;
---

<section id="experience" class="py-32 md:py-40">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <!-- Section label -->
    <div class="section-label">
      <span>{locale === 'es' ? 'Experiencia' : 'Experience'}</span>
    </div>

    <h2 class="exp-title font-display text-3xl md:text-5xl font-bold tracking-tight mb-16 md:mb-24">
      {locale === 'es' ? 'Trayectoria' : 'Journey'}
    </h2>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="timeline-line absolute left-0 md:left-8 top-0 bottom-0 w-px bg-border"></div>

      <div class="space-y-16 md:space-y-20">
        {experience.map((exp, index) => (
          <div class="exp-item relative pl-8 md:pl-20">
            <!-- Timeline dot -->
            <div class="absolute left-0 md:left-8 top-2 -translate-x-1/2 w-3 h-3 border-2 border-accent bg-background z-10"></div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-12">
              <!-- Left: meta -->
              <div>
                <span class="font-mono text-xs text-accent uppercase tracking-wider">{exp.period}</span>
                <p class="font-mono text-xs text-muted mt-1">{exp.location}</p>
              </div>

              <!-- Right: content -->
              <div class="md:col-span-2">
                <h3 class="font-display text-xl md:text-2xl font-bold mb-1">{exp.company}</h3>
                <p class="font-mono text-sm text-muted mb-4">{exp.role}</p>
                <p class="text-base text-muted leading-relaxed">{exp.description}</p>
              </div>
            </div>

            {index < experience.length - 1 && (
              <div class="hidden"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Title reveal
  gsap.from('.exp-title', {
    y: 40,
    autoAlpha: 0,
    duration: 1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: '#experience',
      start: "top 75%"
    }
  });

  // Timeline line draw
  gsap.from('.timeline-line', {
    scaleY: 0,
    transformOrigin: "top",
    duration: 1.5,
    ease: "power2.inOut",
    scrollTrigger: {
      trigger: '#experience .relative',
      start: "top 75%"
    }
  });

  // Experience items stagger in
  gsap.from('.exp-item', {
    x: -40,
    autoAlpha: 0,
    duration: 0.9,
    stagger: 0.2,
    ease: "power3.out",
    scrollTrigger: {
      trigger: '#experience .relative',
      start: "top 70%"
    }
  });
</script>
