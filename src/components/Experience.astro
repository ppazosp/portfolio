---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { experience } = portfolioConfig;
---

<section class="panel" id="experience">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content flex flex-col justify-center">
          <div class="section-label">
            <span>{locale === 'es' ? 'Experiencia' : 'Experience'}</span>
          </div>

          <h2 class="panel-heading font-display text-2xl md:text-4xl font-bold tracking-tight mb-10 md:mb-14">
            {locale === 'es' ? 'Trayectoria' : 'Journey'}
          </h2>

          <!-- Scroll-style timeline -->
          <div class="relative pl-8 md:pl-12" id="timeline">
            <!-- Vertical line (draws on reveal) -->
            <div class="timeline-track absolute left-0 top-0 bottom-0 w-px bg-border">
              <div class="timeline-progress absolute left-0 top-0 w-full bg-accent origin-top" style="height: 0%;"></div>
            </div>

            <div class="space-y-10 md:space-y-14">
              {experience.map((exp, i) => (
                <div class="exp-item relative" data-exp={i}>
                  <!-- Dot on timeline -->
                  <div class="exp-dot absolute -left-8 md:-left-12 top-1 w-5 h-5 flex items-center justify-center">
                    <div class="w-3 h-3 border-2 border-border bg-background rounded-full transition-all duration-500"></div>
                  </div>

                  <!-- Content card -->
                  <div class="exp-card border border-border bg-surface/20 p-5 md:p-7 relative overflow-hidden">
                    <!-- Accent top -->
                    <div class="exp-accent absolute top-0 left-0 h-0.5 bg-accent origin-left" style="width: 0%;"></div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8">
                      <div>
                        <span class="font-mono text-[10px] text-accent uppercase tracking-wider">{exp.period}</span>
                        <p class="font-mono text-[10px] text-muted mt-0.5">{exp.location}</p>
                      </div>
                      <div class="md:col-span-2">
                        <h3 class="font-display text-xl md:text-2xl font-bold mb-1">{exp.company}</h3>
                        <p class="font-mono text-xs text-muted mb-3">{exp.role}</p>
                        <p class="text-sm text-muted leading-relaxed">{exp.description}</p>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  // Animate timeline when panel becomes visible
  const timeline = document.getElementById('timeline');
  if (timeline) {
    const progress = timeline.querySelector('.timeline-progress') as HTMLElement;
    const items = timeline.querySelectorAll<HTMLElement>('.exp-item');
    const dots = timeline.querySelectorAll<HTMLElement>('.exp-dot .w-3');
    const accents = timeline.querySelectorAll<HTMLElement>('.exp-accent');

    // Set initial states
    gsap.set(items, { x: 40, autoAlpha: 0 });
    gsap.set(progress, { height: '0%' });
    gsap.set(accents, { width: '0%' });

    // Watch for panel visibility
    const observer = new MutationObserver(() => {
      const panel = document.getElementById('experience');
      if (panel && panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
        playTimeline();
        observer.disconnect();
      }
    });

    const panel = document.getElementById('experience');
    if (panel) {
      observer.observe(panel, { attributes: true, attributeFilter: ['style'] });
    }

    let played = false;
    function playTimeline() {
      if (played) return;
      played = true;

      const tl = gsap.timeline({ delay: 0.6 });

      // Draw the timeline progressively
      tl.to(progress, { height: '100%', duration: 2, ease: "power1.inOut" }, 0);

      // Each item reveals as the line reaches it
      items.forEach((item, i) => {
        const offset = 0.3 + i * 0.55;

        // Card slides in
        tl.to(item, { x: 0, autoAlpha: 1, duration: 0.6, ease: "power3.out" }, offset);

        // Dot activates
        tl.to(dots[i], {
          borderColor: '#FF4D00',
          backgroundColor: '#FF4D00',
          scale: 1.3,
          duration: 0.3,
          ease: "back.out(2)"
        }, offset);

        // After dot activates, scale back
        tl.to(dots[i], { scale: 1, duration: 0.4, ease: "power2.out" }, offset + 0.3);

        // Accent line draws
        tl.to(accents[i], { width: '100%', duration: 0.5, ease: "power2.out" }, offset + 0.15);
      });
    }

    // Also play if panel is already visible (first load edge case)
    if (panel && panel.style.visibility !== 'hidden') {
      setTimeout(playTimeline, 800);
    }
  }
</script>
