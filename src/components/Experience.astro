---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { experience } = portfolioConfig;
---

<section class="panel" id="experience">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content h-full flex flex-col">
          <div class="section-label mb-3">
            <span>{locale === 'es' ? 'Experiencia' : 'Experience'}</span>
          </div>

          <!-- Slides area -->
          <div class="flex-1 flex items-center min-h-0">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 w-full items-start">

              <!-- Timeline track (left, 1 col) -->
              <div class="hidden md:flex md:col-span-1 flex-col items-center relative" id="exp-timeline-track">
                <div class="relative w-px h-full min-h-[18rem]" style="background: var(--color-border);">
                  <div class="exp-timeline-progress absolute left-0 top-0 w-full origin-top" style="height: 0%; background: var(--color-accent);"></div>
                  {experience.map((_, i) => (
                    <button
                      class="exp-timeline-dot absolute left-1/2 -translate-x-1/2 w-3 h-3 rounded-full border-2 transition-all duration-500 cursor-pointer"
                      data-exp-slide={i}
                      style={`top: ${i * (100 / (experience.length - 1))}%; border-color: ${i === 0 ? 'var(--color-accent)' : 'var(--color-border)'}; background: ${i === 0 ? 'var(--color-accent)' : 'var(--color-background)'};`}
                    ></button>
                  ))}
                </div>
              </div>

              <!-- Experience slides (11 cols) -->
              <div class="md:col-span-11 relative" style="min-height: 18rem;">
                {experience.map((exp, i) => (
                  <div
                    class="exp-slide md:absolute md:top-0 md:left-0 md:w-full"
                    data-exp={i}
                    style={i > 0 ? 'visibility: hidden;' : ''}
                  >
                    <!-- Period + location label -->
                    <div class="exp-tagline font-mono text-[10px] uppercase tracking-[0.2em] mb-4" style="color: var(--color-accent);">
                      <span style="color: var(--color-accent); opacity: 0.5;">{String(i + 1).padStart(2, '0')}</span>
                      <span class="mx-2" style="color: var(--color-accent); opacity: 0.25;">/</span>
                      {exp.period}
                    </div>

                    <!-- Company name -->
                    <h3 class="exp-name overflow-hidden mb-2">
                      <span class="exp-name-inner block font-display font-extrabold tracking-[-0.03em] leading-[0.9]"
                            style="font-size: clamp(2rem, 5vw, 4.5rem);">
                        {exp.company}
                      </span>
                    </h3>

                    <!-- Role -->
                    <p class="exp-role font-mono text-xs text-muted mb-4">{exp.role}</p>

                    <!-- Divider -->
                    <div class="exp-divider h-[1px] w-full mb-5" style="background: linear-gradient(to right, var(--color-accent), transparent);"></div>

                    <!-- Description -->
                    <p class="exp-desc text-sm text-muted leading-relaxed mb-5 max-w-2xl">
                      {exp.description}
                    </p>

                    <!-- Location tag -->
                    <div class="exp-location">
                      <span class="font-mono text-[10px] px-3 py-1 border text-muted/70"
                            style="border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);">
                        {exp.location}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Counter (bottom right, tight to content) -->
          <div class="relative z-20 flex items-center justify-end pt-1">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5" id="exp-pips">
                {experience.map((_, i) => (
                  <button
                    class="exp-dot w-2 h-2 rounded-full cursor-pointer transition-all duration-400"
                    data-exp-slide={i}
                    style={`background: ${i === 0 ? 'var(--color-accent)' : 'var(--color-border)'};`}
                  ></button>
                ))}
              </div>
              <span class="font-mono text-xs text-muted/40" id="exp-counter">
                01 — {String(experience.length).padStart(2, '0')}
              </span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const allSlides = document.querySelectorAll<HTMLElement>('.exp-slide');
  const dots = document.querySelectorAll<HTMLElement>('#exp-pips .exp-dot');
  const timelineDots = document.querySelectorAll<HTMLElement>('.exp-timeline-dot');
  const timelineProgress = document.querySelector<HTMLElement>('.exp-timeline-progress');
  const counter = document.getElementById('exp-counter');

  if (allSlides.length > 0) {
    let current = 0;
    let expAnimating = false;
    const total = allSlides.length;
    const accentColor = '#7B61FF';

    function getEls(i: number) {
      const s = allSlides[i];
      return {
        slide: s,
        tagline: s.querySelector('.exp-tagline') as HTMLElement,
        nameInner: s.querySelector('.exp-name-inner') as HTMLElement,
        role: s.querySelector('.exp-role') as HTMLElement,
        divider: s.querySelector('.exp-divider') as HTMLElement,
        desc: s.querySelector('.exp-desc') as HTMLElement,
        location: s.querySelector('.exp-location') as HTMLElement,
      };
    }

    function updateIndicator() {
      // Bottom dots
      dots.forEach((dot, i) => {
        dot.style.background = i === current ? accentColor : 'var(--color-border)';
        dot.style.transform = i === current ? 'scale(1.4)' : 'scale(1)';
      });
      // Timeline dots
      timelineDots.forEach((dot, i) => {
        dot.style.borderColor = i <= current ? accentColor : 'var(--color-border)';
        dot.style.background = i <= current ? accentColor : 'var(--color-background)';
        dot.style.transform = i === current ? 'scale(1.3)' : 'scale(1)';
      });
      // Timeline progress
      if (timelineProgress) {
        const pct = total > 1 ? (current / (total - 1)) * 100 : 0;
        gsap.to(timelineProgress, { height: `${pct}%`, duration: 0.8, ease: "power2.inOut" });
      }
      // Counter
      if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} — ${String(total).padStart(2, '0')}`;
    }

    function updateIndicatorTo(idx: number) {
      dots.forEach((dot, i) => {
        dot.style.background = i === idx ? accentColor : 'var(--color-border)';
        dot.style.transform = i === idx ? 'scale(1.4)' : 'scale(1)';
      });
      timelineDots.forEach((dot, i) => {
        dot.style.borderColor = i <= idx ? accentColor : 'var(--color-border)';
        dot.style.background = i <= idx ? accentColor : 'var(--color-background)';
        dot.style.transform = i === idx ? 'scale(1.3)' : 'scale(1)';
      });
      if (timelineProgress) {
        const pct = total > 1 ? (idx / (total - 1)) * 100 : 0;
        gsap.to(timelineProgress, { height: `${pct}%`, duration: 0.8, ease: "power2.inOut" });
      }
      if (counter) counter.textContent = `${String(idx + 1).padStart(2, '0')} — ${String(total).padStart(2, '0')}`;
    }

    function goToSlide(index: number) {
      if (expAnimating || index === current || index < 0 || index >= total) return;
      expAnimating = true;

      const dir = index > current ? 1 : -1;
      const cur = getEls(current);
      const nxt = getEls(index);

      // Update timeline + dots immediately with the transition
      updateIndicatorTo(index);

      const tl = gsap.timeline({
        defaults: { ease: "power3.inOut" },
        onComplete: () => {
          cur.slide.style.visibility = 'hidden';
          current = index;
          expAnimating = false;
        }
      });

      // ── OUT ──
      tl.to(cur.nameInner, { yPercent: -120 * dir, duration: 0.7 }, 0);
      tl.to(cur.tagline, { y: -15 * dir, autoAlpha: 0, duration: 0.5 }, 0);
      tl.to(cur.role, { y: -10 * dir, autoAlpha: 0, duration: 0.4 }, 0.05);
      tl.to(cur.divider, { scaleX: 0, transformOrigin: 'left', duration: 0.5 }, 0);
      tl.to(cur.desc, { y: -20 * dir, autoAlpha: 0, duration: 0.5 }, 0.1);
      tl.to(cur.location, { y: -10 * dir, autoAlpha: 0, duration: 0.4 }, 0.1);

      // ── IN ──
      gsap.set(nxt.slide, { visibility: 'visible' });
      gsap.set(nxt.nameInner, { yPercent: 120 * dir });
      gsap.set(nxt.tagline, { y: 25 * dir, autoAlpha: 0 });
      gsap.set(nxt.role, { y: 15 * dir, autoAlpha: 0 });
      gsap.set(nxt.divider, { scaleX: 0, transformOrigin: 'left' });
      gsap.set(nxt.desc, { y: 30 * dir, autoAlpha: 0 });
      gsap.set(nxt.location, { y: 15 * dir, autoAlpha: 0 });

      tl.to(nxt.nameInner, { yPercent: 0, duration: 0.9, ease: "power4.out" }, 0.5);
      tl.to(nxt.tagline, { y: 0, autoAlpha: 1, duration: 0.6, ease: "power2.out" }, 0.6);
      tl.to(nxt.role, { y: 0, autoAlpha: 1, duration: 0.5, ease: "power2.out" }, 0.65);
      tl.to(nxt.divider, { scaleX: 1, duration: 0.6, ease: "power2.out" }, 0.7);
      tl.to(nxt.desc, { y: 0, autoAlpha: 1, duration: 0.7, ease: "power2.out" }, 0.8);
      tl.to(nxt.location, { y: 0, autoAlpha: 1, duration: 0.5, ease: "power2.out" }, 0.9);
    }

    updateIndicator();

    // Click handlers for dots
    dots.forEach((dot, i) => dot.addEventListener('click', () => goToSlide(i)));
    timelineDots.forEach((dot, i) => dot.addEventListener('click', () => goToSlide(i)));

    // Expose carousel API for panel engine
    (window as any).__expCarousel = {
      next: () => goToSlide(current + 1),
      prev: () => goToSlide(current - 1),
      isFirst: () => current === 0,
      isLast: () => current === total - 1,
      isAnimating: () => expAnimating,
    };
  }
</script>
