---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { experience } = portfolioConfig;
---

<section id="experience" class="py-32 md:py-40">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="section-label">
      <span>{locale === 'es' ? 'Experiencia' : 'Experience'}</span>
    </div>

    <h2 class="exp-heading font-display text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-16 md:mb-24">
      {(locale === 'es' ? 'Trayectoria' : 'Journey').split('').map((char, i) => (
        <span class="split-char inline-block" style={`--ci: ${i}`}>
          {char}
        </span>
      ))}
    </h2>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="timeline-line absolute left-0 md:left-8 top-0 bottom-0 w-px bg-border origin-top"></div>

      <div class="space-y-16 md:space-y-24">
        {experience.map((exp, index) => (
          <div class="exp-item relative pl-8 md:pl-20">
            <!-- Timeline dot with pulse -->
            <div class="absolute left-0 md:left-8 top-2 -translate-x-1/2">
              <div class="w-3 h-3 border-2 border-accent bg-background z-10 relative"></div>
              <div class="absolute inset-0 -m-1 border border-accent/30 animate-ping" style="animation-duration: 3s;"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-12">
              <div>
                <span class="font-mono text-xs text-accent uppercase tracking-wider">{exp.period}</span>
                <p class="font-mono text-xs text-muted mt-1">{exp.location}</p>
              </div>

              <div class="md:col-span-2">
                <h3 class="font-display text-xl md:text-3xl font-bold mb-1">{exp.company}</h3>
                <p class="font-mono text-sm text-muted mb-4">{exp.role}</p>
                <p class="text-base text-muted leading-relaxed">{exp.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Character heading reveal
  gsap.from('#experience .split-char', {
    y: 80,
    rotationX: -60,
    autoAlpha: 0,
    duration: 0.8,
    stagger: 0.04,
    ease: "back.out(1.7)",
    scrollTrigger: {
      trigger: '.exp-heading',
      start: "top 80%"
    }
  });

  // Timeline line draw with scrub
  gsap.from('.timeline-line', {
    scaleY: 0,
    duration: 2,
    ease: "none",
    scrollTrigger: {
      trigger: '#experience .relative',
      start: "top 70%",
      end: "bottom 50%",
      scrub: 1
    }
  });

  // Experience items stagger with 3D
  gsap.from('.exp-item', {
    x: -60,
    rotationY: -3,
    autoAlpha: 0,
    duration: 1,
    stagger: 0.25,
    ease: "power3.out",
    scrollTrigger: {
      trigger: '#experience .relative',
      start: "top 70%"
    }
  });
</script>
