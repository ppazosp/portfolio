---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { experience } = portfolioConfig;
---

<section class="panel" id="experience">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content">
          <div class="section-label">
            <span>{locale === 'es' ? 'Experiencia' : 'Experience'}</span>
          </div>

          <h2 class="panel-heading font-display text-2xl md:text-4xl font-bold tracking-tight mb-8 md:mb-12">
            {locale === 'es' ? 'Trayectoria' : 'Journey'}
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
            {experience.map((exp, i) => (
              <div class="border-l-2 border-accent/30 pl-6 relative">
                <div class="absolute left-0 top-0 -translate-x-[5px] w-2 h-2 bg-accent rounded-full"></div>
                <span class="font-mono text-[10px] text-accent uppercase tracking-wider">{exp.period}</span>
                <p class="font-mono text-[10px] text-muted mt-0.5 mb-3">{exp.location}</p>
                <h3 class="font-display text-xl md:text-2xl font-bold mb-1">{exp.company}</h3>
                <p class="font-mono text-xs text-muted mb-3">{exp.role}</p>
                <p class="text-sm text-muted leading-relaxed">{exp.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
