---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section class="panel" id="projects">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content flex flex-col justify-center relative">

          <!-- Section header -->
          <div class="section-label">
            <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
          </div>

          <!-- Stacked full-screen project slides -->
          <div class="relative flex-1 flex items-center">
            {projects.map((project, i) => (
              <div
                class="project-slide absolute inset-0 flex items-center"
                data-slide={i}
                data-color={project.color}
                style={i > 0 ? 'visibility: hidden;' : ''}
              >
                <div class="w-full">
                  <!-- Top bar: label + counter -->
                  <div class="flex items-center justify-between mb-6 md:mb-8">
                    <span class="slide-tagline font-mono text-[10px] md:text-xs uppercase tracking-[0.2em]" style={`color: ${project.color};`}>
                      {project.tagline}
                    </span>
                    <span class="slide-tagline font-mono text-xs text-muted/30">
                      {String(i + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}
                    </span>
                  </div>

                  <!-- Main grid -->
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-0 items-start">
                    <!-- Color block visual (5 cols) -->
                    <div class="md:col-span-5 relative">
                      <div class="slide-img relative h-52 md:h-[26rem] overflow-hidden" style={`background: ${project.color};`}>
                        <!-- Giant number -->
                        <span class="absolute top-4 left-5 md:top-6 md:left-7 font-display font-extrabold text-7xl md:text-9xl leading-none select-none"
                              style="color: rgba(0,0,0,0.2);">
                          {String(i + 1).padStart(2, '0')}
                        </span>
                        <!-- Giant letter -->
                        <span class="absolute bottom-0 right-0 font-display font-extrabold select-none pointer-events-none translate-x-[10%] translate-y-[5%]"
                              style={`font-size: clamp(12rem, 30vw, 24rem); color: rgba(0,0,0,0.12); line-height: 0.75;`}>
                          {project.name.charAt(0)}
                        </span>
                        <!-- Placeholder text -->
                        <span class="absolute bottom-5 left-5 md:bottom-7 md:left-7 font-mono text-[9px] uppercase tracking-[0.2em]"
                              style="color: rgba(0,0,0,0.35);">
                          {locale === 'es' ? 'Imagen proximamente' : 'Image coming soon'}
                        </span>
                      </div>
                    </div>

                    <!-- Info (7 cols, offset) -->
                    <div class="md:col-span-6 md:col-start-7 flex flex-col justify-center">
                      <!-- Project name -->
                      <h3 class="slide-name overflow-hidden mb-4">
                        <span class="slide-name-inner block font-display font-extrabold tracking-[-0.03em] leading-[0.9]"
                              style="font-size: clamp(2.5rem, 6vw, 5rem);">
                          {project.name}
                        </span>
                      </h3>

                      <!-- Colored divider -->
                      <div class="slide-divider h-0.5 w-16 mb-5" style={`background: ${project.color};`}></div>

                      <!-- Description -->
                      <p class="slide-desc text-sm md:text-base text-muted leading-relaxed mb-6 max-w-lg">
                        {project.description}
                      </p>

                      <!-- Tech tags -->
                      <div class="slide-tags flex flex-wrap gap-2">
                        {project.tech.map((t) => (
                          <span class="font-mono text-[10px] px-3 py-1.5 border text-muted/70 transition-colors"
                                style={`border-color: ${project.color}30;`}>
                            {t}
                          </span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Bottom: progress dots -->
          <div class="flex items-center justify-between mt-2 relative z-20">
            <div class="flex gap-2" id="project-dots">
              {projects.map((project, i) => (
                <button
                  class="project-dot h-1 cursor-pointer transition-all duration-500"
                  data-slide={i}
                  style={`width: ${i === 0 ? '3rem' : '1.5rem'}; background: ${i === 0 ? project.color : 'var(--color-border)'};`}
                ></button>
              ))}
            </div>
            <span class="font-mono text-[10px] text-muted/20">scroll to navigate</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const allSlides = document.querySelectorAll<HTMLElement>('.project-slide');
  const dots = document.querySelectorAll<HTMLElement>('.project-dot');

  if (allSlides.length > 0) {
    let current = 0;
    let carouselAnimating = false;
    const total = allSlides.length;

    function getEls(i: number) {
      const s = allSlides[i];
      return {
        slide: s,
        img: s.querySelector('.slide-img') as HTMLElement,
        nameInner: s.querySelector('.slide-name-inner') as HTMLElement,
        taglines: s.querySelectorAll('.slide-tagline'),
        divider: s.querySelector('.slide-divider') as HTMLElement,
        desc: s.querySelector('.slide-desc') as HTMLElement,
        tags: s.querySelectorAll('.slide-tags span'),
      };
    }

    function updateDots() {
      dots.forEach((dot, i) => {
        const color = allSlides[i].dataset.color || '#FF4D00';
        dot.style.width = i === current ? '3rem' : '1.5rem';
        dot.style.background = i === current ? color : 'var(--color-border)';
      });
    }

    function goToSlide(index: number) {
      if (carouselAnimating || index === current || index < 0 || index >= total) return;
      carouselAnimating = true;

      const dir = index > current ? 1 : -1;
      const cur = getEls(current);
      const nxt = getEls(index);

      const tl = gsap.timeline({
        defaults: { ease: "power3.inOut" },
        onComplete: () => {
          cur.slide.style.visibility = 'hidden';
          current = index;
          carouselAnimating = false;
          updateDots();
        }
      });

      // ── OUT: current slide ──
      tl.to(cur.img, { xPercent: -15 * dir, scale: 0.92, autoAlpha: 0, duration: 0.9 }, 0);
      tl.to(cur.nameInner, { yPercent: -120 * dir, duration: 0.7 }, 0);
      tl.to(cur.taglines, { y: -15 * dir, autoAlpha: 0, duration: 0.5 }, 0);
      tl.to(cur.divider, { scaleX: 0, transformOrigin: 'left', duration: 0.5 }, 0);
      tl.to(cur.desc, { y: -20 * dir, autoAlpha: 0, duration: 0.5 }, 0.1);
      tl.to(cur.tags, { y: -10 * dir, autoAlpha: 0, stagger: 0.02, duration: 0.4 }, 0.1);

      // ── IN: new slide ──
      gsap.set(nxt.slide, { visibility: 'visible' });
      gsap.set(nxt.img, { xPercent: 20 * dir, scale: 1.08, autoAlpha: 0 });
      gsap.set(nxt.nameInner, { yPercent: 120 * dir });
      gsap.set(nxt.taglines, { y: 25 * dir, autoAlpha: 0 });
      gsap.set(nxt.divider, { scaleX: 0, transformOrigin: 'left' });
      gsap.set(nxt.desc, { y: 30 * dir, autoAlpha: 0 });
      gsap.set(nxt.tags, { y: 15 * dir, autoAlpha: 0 });

      tl.to(nxt.img, { xPercent: 0, scale: 1, autoAlpha: 1, duration: 1, ease: "power2.out" }, 0.5);
      tl.to(nxt.nameInner, { yPercent: 0, duration: 0.9, ease: "power4.out" }, 0.6);
      tl.to(nxt.divider, { scaleX: 1, duration: 0.6, ease: "power2.out" }, 0.8);
      tl.to(nxt.taglines, { y: 0, autoAlpha: 1, duration: 0.6, ease: "power2.out" }, 0.7);
      tl.to(nxt.desc, { y: 0, autoAlpha: 1, duration: 0.7, ease: "power2.out" }, 0.85);
      tl.to(nxt.tags, { y: 0, autoAlpha: 1, stagger: 0.04, duration: 0.5, ease: "power2.out" }, 0.95);
    }

    updateDots();
    dots.forEach((dot, i) => dot.addEventListener('click', () => goToSlide(i)));

    (window as any).__carousel = {
      next: () => goToSlide(current + 1),
      prev: () => goToSlide(current - 1),
      isFirst: () => current === 0,
      isLast: () => current === total - 1,
      isAnimating: () => carouselAnimating,
    };
  }
</script>
