---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section class="panel" id="projects">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content">
          <div class="section-label">
            <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
          </div>

          <h2 class="panel-heading font-display text-2xl md:text-4xl font-bold tracking-tight mb-6 md:mb-8">
            {locale === 'es' ? 'Lo que he construido' : 'What I\'ve built'}
          </h2>

          <!-- Interactive project cards -->
          <div class="projects-grid grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4">
            {projects.slice(0, 3).map((project, i) => (
              <div
                class="project-card relative border border-border bg-surface/20 overflow-hidden cursor-pointer group"
                style={`--project-color: ${project.color}; --i: ${i};`}
                data-name={project.name}
                data-tagline={project.tagline}
                data-description={project.description}
                data-color={project.color}
                data-tech={project.tech.join(',')}
              >
                <div class="h-0.5 w-full" style={`background: ${project.color};`}></div>
                <span class="absolute top-4 right-4 font-display font-extrabold text-6xl md:text-7xl select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 group-hover:rotate-6"
                      style={`color: ${project.color}; opacity: 0.06;`}>{String(i + 1).padStart(2, '0')}</span>
                <div class="relative z-10 p-5 md:p-6">
                  <div class="flex items-baseline justify-between mb-2">
                    <h3 class="font-display text-lg md:text-xl font-bold group-hover:text-accent transition-colors duration-300">{project.name}</h3>
                    <span class="font-mono text-[9px] text-muted/40">{String(i + 1).padStart(2, '0')}</span>
                  </div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-3" style={`color: ${project.color};`}>{project.tagline}</p>
                  <p class="text-xs text-muted leading-relaxed mb-4 line-clamp-2">{project.description}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {project.tech.slice(0, 3).map((t) => (
                      <span class="font-mono text-[8px] px-2 py-0.5 border border-border text-muted/60 group-hover:border-muted/30 transition-colors">{t}</span>
                    ))}
                  </div>
                </div>
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                     style={`background: radial-gradient(ellipse at 50% 0%, ${project.color}10 0%, transparent 70%);`}></div>
              </div>
            ))}
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4 mt-3 md:mt-4">
            {projects.slice(3).map((project, i) => (
              <div
                class="project-card relative border border-border bg-surface/20 overflow-hidden cursor-pointer group"
                style={`--project-color: ${project.color}; --i: ${i + 3};`}
                data-name={project.name}
                data-tagline={project.tagline}
                data-description={project.description}
                data-color={project.color}
                data-tech={project.tech.join(',')}
              >
                <div class="h-0.5 w-full" style={`background: ${project.color};`}></div>
                <span class="absolute top-4 right-4 font-display font-extrabold text-6xl md:text-7xl select-none pointer-events-none transition-transform duration-700 group-hover:scale-110 group-hover:rotate-6"
                      style={`color: ${project.color}; opacity: 0.06;`}>{String(i + 4).padStart(2, '0')}</span>
                <div class="relative z-10 p-5 md:p-6">
                  <div class="flex items-baseline justify-between mb-2">
                    <h3 class="font-display text-lg md:text-xl font-bold group-hover:text-accent transition-colors duration-300">{project.name}</h3>
                    <span class="font-mono text-[9px] text-muted/40">{String(i + 4).padStart(2, '0')}</span>
                  </div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-3" style={`color: ${project.color};`}>{project.tagline}</p>
                  <p class="text-xs text-muted leading-relaxed mb-4 line-clamp-2">{project.description}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {project.tech.slice(0, 3).map((t) => (
                      <span class="font-mono text-[8px] px-2 py-0.5 border border-border text-muted/60 group-hover:border-muted/30 transition-colors">{t}</span>
                    ))}
                  </div>
                </div>
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                     style={`background: radial-gradient(ellipse at 50% 0%, ${project.color}10 0%, transparent 70%);`}></div>
              </div>
            ))}
          </div>

          <!-- Expanded project detail overlay -->
          <div id="project-detail" class="fixed inset-0 z-[100] pointer-events-none" style="visibility: hidden;">
            <div class="project-overlay absolute inset-0 bg-background/90 backdrop-blur-md"></div>
            <div class="project-detail-content absolute inset-0 flex items-center justify-center p-8 md:p-16">
              <div class="max-w-3xl w-full relative">
                <button id="close-detail" class="absolute -top-8 right-0 font-mono text-xs text-muted hover:text-accent transition-colors cursor-pointer">
                  [{locale === 'es' ? 'cerrar' : 'close'}]
                </button>
                <div class="border border-border bg-surface/50 p-8 md:p-12">
                  <div class="h-1 w-24 mb-6" id="detail-accent"></div>
                  <h3 class="font-display text-3xl md:text-5xl font-bold mb-2" id="detail-name"></h3>
                  <p class="font-mono text-xs uppercase tracking-[0.15em] mb-6" id="detail-tagline"></p>
                  <p class="text-base text-muted leading-relaxed mb-8" id="detail-description"></p>
                  <div class="flex flex-wrap gap-2" id="detail-tech"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .project-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.3s;
  }
  .project-card:hover {
    transform: translateY(-3px);
  }
</style>

<script>
  import gsap from 'gsap';

  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const detail = document.getElementById('project-detail');
  const closeBtn = document.getElementById('close-detail');

  if (detail && closeBtn) {
    // 3D tilt on hover
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        gsap.to(card, { rotationY: x * 8, rotationX: -y * 5, transformPerspective: 800, duration: 0.4, ease: "power2.out" });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { rotationY: 0, rotationX: 0, duration: 0.6, ease: "elastic.out(1, 0.4)" });
      });

      // Click to expand detail
      card.addEventListener('click', () => {
        const name = card.dataset.name || '';
        const tagline = card.dataset.tagline || '';
        const description = card.dataset.description || '';
        const color = card.dataset.color || '#FF4D00';
        const techs = (card.dataset.tech || '').split(',');

        const detailName = document.getElementById('detail-name');
        const detailTagline = document.getElementById('detail-tagline');
        const detailDesc = document.getElementById('detail-description');
        const detailAccent = document.getElementById('detail-accent');
        const detailTech = document.getElementById('detail-tech');

        if (detailName) detailName.textContent = name;
        if (detailTagline) { detailTagline.textContent = tagline; detailTagline.style.color = color; }
        if (detailDesc) detailDesc.textContent = description;
        if (detailAccent) detailAccent.style.background = color;
        if (detailTech) {
          detailTech.textContent = '';
          techs.forEach(t => {
            const span = document.createElement('span');
            span.className = 'font-mono text-xs px-3 py-1 border border-border text-muted';
            span.textContent = t;
            detailTech.appendChild(span);
          });
        }

        detail.style.visibility = 'visible';
        detail.style.pointerEvents = 'auto';
        gsap.fromTo('.project-overlay', { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.3 });
        gsap.fromTo('.project-detail-content', { y: 60, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.5, ease: "power3.out", delay: 0.1 });
      });
    });

    function closeDetail() {
      gsap.to('.project-detail-content', { y: 40, autoAlpha: 0, duration: 0.3, ease: "power2.in" });
      gsap.to('.project-overlay', { autoAlpha: 0, duration: 0.3, delay: 0.1, onComplete: () => {
        if (detail) {
          detail.style.visibility = 'hidden';
          detail.style.pointerEvents = 'none';
        }
      }});
    }

    closeBtn.addEventListener('click', closeDetail);
    document.querySelector('.project-overlay')?.addEventListener('click', closeDetail);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && detail.style.visibility === 'visible') closeDetail();
    });
  }
</script>
