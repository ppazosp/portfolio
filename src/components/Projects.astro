---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section id="projects" class="relative">
  <!-- Section header (scrolls normally) -->
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 pt-32 md:pt-40 pb-12">
    <div class="section-label">
      <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
    </div>
    <h2 class="projects-title font-display text-3xl md:text-5xl font-bold tracking-tight">
      {locale === 'es' ? 'Lo que he construido' : 'What I\'ve built'}
    </h2>
  </div>

  <!-- Horizontal scroll viewport -->
  <div class="projects-viewport overflow-hidden">
    <div class="projects-track flex flex-col md:flex-row gap-6 md:gap-8 px-6 md:px-12 pb-32 md:pb-40 items-stretch">
      {projects.map((project, index) => (
        <div
          class="project-card w-full md:w-[50vw] md:flex-shrink-0 lg:w-[40vw] border border-border bg-surface/30 flex flex-col justify-between relative overflow-hidden group"
          style={`--project-color: ${project.color};`}
        >
          <!-- Colored top accent -->
          <div class="h-1 w-full" style={`background: ${project.color};`}></div>

          <!-- Glow on hover -->
          <div
            class="absolute -top-20 -right-20 w-60 h-60 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none blur-[80px]"
            style={`background: ${project.color}; opacity: 0;`}
          ></div>

          <div class="relative z-10 p-8 md:p-10 flex flex-col flex-1">
            <!-- Number -->
            <span class="font-mono text-xs text-muted/50 mb-6">
              {String(index + 1).padStart(2, '0')}
            </span>

            <!-- Name -->
            <h3 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold mb-2 tracking-tight">
              {project.name}
            </h3>

            <!-- Tagline -->
            <p class="font-mono text-xs uppercase tracking-[0.15em] mb-6" style={`color: ${project.color};`}>
              {project.tagline}
            </p>

            <!-- Description -->
            <p class="text-sm md:text-base text-muted leading-relaxed flex-1">
              {project.description}
            </p>

            <!-- Tech tags -->
            <div class="mt-8 flex flex-wrap gap-2">
              {project.tech.map((t) => (
                <span class="font-mono text-[11px] px-3 py-1.5 border border-border text-muted/70">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll progress indicator (desktop only) -->
  <div class="hidden md:block absolute bottom-12 left-12 right-12 pointer-events-none">
    <div class="h-px bg-border relative">
      <div class="projects-progress h-px bg-accent absolute top-0 left-0 w-0"></div>
    </div>
  </div>
</section>

<style>
  .project-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-card:hover {
    transform: translateY(-4px);
  }

  .project-card:hover .absolute.rounded-full {
    opacity: 0.06 !important;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const track = document.querySelector('.projects-track') as HTMLElement;
  const viewport = document.querySelector('.projects-viewport') as HTMLElement;
  const section = document.querySelector('#projects') as HTMLElement;
  const progress = document.querySelector('.projects-progress') as HTMLElement;

  if (track && section) {
    const mm = gsap.matchMedia();

    // Title reveal
    gsap.from('.projects-title', {
      y: 40,
      autoAlpha: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '#projects',
        start: "top 75%"
      }
    });

    // Desktop: horizontal scroll
    mm.add("(min-width: 768px)", () => {
      const scrollTween = gsap.to(track, {
        x: () => -(track.scrollWidth - window.innerWidth + 48),
        ease: "none",
        scrollTrigger: {
          trigger: section,
          pin: true,
          scrub: 1,
          start: "top top",
          end: () => "+=" + (track.scrollWidth - window.innerWidth),
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            if (progress) {
              progress.style.width = `${self.progress * 100}%`;
            }
          }
        }
      });

      return () => {
        scrollTween.kill();
      };
    });

    // Mobile: staggered card reveal
    mm.add("(max-width: 767px)", () => {
      gsap.from('.project-card', {
        y: 80,
        autoAlpha: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: '.projects-track',
          start: "top 80%"
        }
      });
    });
  }
</script>
