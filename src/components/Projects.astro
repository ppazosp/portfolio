---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section id="projects" class="relative">
  <!-- Section header -->
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 pt-32 md:pt-40 pb-12">
    <div class="section-label">
      <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
    </div>
    <h2 class="projects-title font-display text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight">
      {locale === 'es' ? 'Lo que he construido' : 'What I\'ve built'}
    </h2>
  </div>

  <!-- Horizontal scroll viewport -->
  <div class="projects-viewport overflow-hidden">
    <div class="projects-track flex flex-col md:flex-row gap-6 md:gap-8 px-6 md:px-12 pb-32 md:pb-40 items-stretch">
      {projects.map((project, index) => (
        <div
          class="project-card w-full md:w-[55vw] md:flex-shrink-0 lg:w-[45vw] border border-border bg-surface/30 flex flex-col relative overflow-hidden group"
          style={`--project-color: ${project.color};`}
        >
          <!-- Visual placeholder header -->
          <div class="project-visual h-48 md:h-56 relative" style={`background: linear-gradient(135deg, ${project.color}15 0%, ${project.color}05 50%, transparent 100%);`}>
            <!-- Large initial letter -->
            <span
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-display font-extrabold select-none"
              style={`font-size: 12rem; color: ${project.color}; opacity: 0.06; line-height: 1;`}
            >
              {project.name.charAt(0)}
            </span>
            <!-- Floating number -->
            <span class="absolute top-6 right-6 font-mono text-xs text-muted/30">
              {String(index + 1).padStart(2, '0')}
            </span>
            <!-- Grid decoration -->
            <div class="absolute inset-0 opacity-20"
                 style={`background-image: radial-gradient(circle, ${project.color}15 1px, transparent 1px); background-size: 20px 20px;`}>
            </div>
            <!-- Colored top accent -->
            <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${project.color};`}></div>
          </div>

          <!-- Glow on hover -->
          <div
            class="absolute top-0 left-0 w-full h-56 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
            style={`background: radial-gradient(ellipse at 50% 30%, ${project.color}12 0%, transparent 70%);`}
          ></div>

          <div class="relative z-10 p-8 md:p-10 flex flex-col flex-1">
            <!-- Name -->
            <h3 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold mb-2 tracking-tight">
              {project.name}
            </h3>

            <!-- Tagline -->
            <p class="font-mono text-xs uppercase tracking-[0.15em] mb-6" style={`color: ${project.color};`}>
              {project.tagline}
            </p>

            <!-- Description -->
            <p class="text-sm md:text-base text-muted leading-relaxed flex-1">
              {project.description}
            </p>

            <!-- Tech tags -->
            <div class="mt-8 flex flex-wrap gap-2">
              {project.tech.map((t) => (
                <span class="font-mono text-[11px] px-3 py-1.5 border border-border text-muted/70 hover:border-muted/30 transition-colors">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll progress indicator (desktop only) -->
  <div class="hidden md:block absolute bottom-12 left-12 right-12 pointer-events-none">
    <div class="h-px bg-border relative">
      <div class="projects-progress h-px bg-accent absolute top-0 left-0 w-0 transition-none"></div>
    </div>
  </div>
</section>

<style>
  .project-card {
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-card:hover {
    transform: translateY(-6px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const track = document.querySelector('.projects-track') as HTMLElement;
  const section = document.querySelector('#projects') as HTMLElement;
  const progress = document.querySelector('.projects-progress') as HTMLElement;

  if (track && section) {
    const mm = gsap.matchMedia();

    // Title reveal with clip-path
    gsap.from('.projects-title', {
      y: 60,
      autoAlpha: 0,
      duration: 1.2,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '#projects',
        start: "top 75%"
      }
    });

    // Project visual clip-path reveals
    gsap.from('.project-visual', {
      clipPath: 'inset(0 100% 0 0)',
      duration: 1.2,
      stagger: 0.15,
      ease: "power3.inOut",
      scrollTrigger: {
        trigger: '.projects-track',
        start: "top 80%"
      }
    });

    // Desktop: horizontal scroll
    mm.add("(min-width: 768px)", () => {
      const scrollTween = gsap.to(track, {
        x: () => -(track.scrollWidth - window.innerWidth + 48),
        ease: "none",
        scrollTrigger: {
          trigger: section,
          pin: true,
          scrub: 1,
          start: "top top",
          end: () => "+=" + (track.scrollWidth - window.innerWidth),
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            if (progress) {
              progress.style.width = `${self.progress * 100}%`;
            }
          }
        }
      });

      return () => {
        scrollTween.kill();
      };
    });

    // Mobile: staggered card reveal
    mm.add("(max-width: 767px)", () => {
      gsap.from('.project-card', {
        y: 100,
        autoAlpha: 0,
        duration: 0.9,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: '.projects-track',
          start: "top 80%"
        }
      });
    });
  }
</script>
