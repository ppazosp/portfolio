---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section class="panel" id="projects">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content relative h-full flex flex-col">

          <!-- Section header -->
          <div class="section-label mb-3 relative z-20">
            <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
          </div>

          <!-- Slides area -->
          <div class="relative flex-1 min-h-0 max-h-[75vh]">
            {projects.map((project, i) => (
              <div
                class="project-slide absolute top-0 left-0 w-full h-full flex items-center"
                data-slide={i}
                data-color={project.color}
                style={i > 0 ? 'visibility: hidden;' : ''}
              >
                <div class="grid grid-cols-1 md:grid-cols-12 gap-2 w-full items-start">
                  <!-- Color block (cols 1-5) -->
                  <div class="md:col-span-5">
                    <div class="slide-img relative h-44 md:h-[22rem] overflow-hidden" style={`background: ${project.color};`}>
                      <span class="absolute top-3 left-4 md:top-5 md:left-6 font-display font-extrabold text-6xl md:text-8xl leading-none select-none"
                            style="color: rgba(0,0,0,0.2);">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <span class="absolute bottom-0 right-0 font-display font-extrabold select-none pointer-events-none translate-x-[10%] translate-y-[5%]"
                            style={`font-size: clamp(10rem, 25vw, 20rem); color: rgba(0,0,0,0.12); line-height: 0.75;`}>
                        {project.name.charAt(0)}
                      </span>
                      <span class="absolute bottom-3 left-4 md:bottom-5 md:left-6 font-mono text-[8px] uppercase tracking-[0.2em]"
                            style="color: rgba(0,0,0,0.3);">
                        {locale === 'es' ? 'Imagen proximamente' : 'Image coming soon'}
                      </span>
                    </div>
                  </div>

                  <!-- Info (cols 7-11, 1 col gap each side) -->
                  <div class="md:col-span-5 md:col-start-7 flex flex-col">
                    <div class="slide-tagline font-mono text-[10px] uppercase tracking-[0.2em] mb-4" style={`color: ${project.color};`}>
                      <span style={`color: ${project.color}60;`}>{String(i + 1).padStart(2, '0')}</span>
                      <span class="mx-2" style={`color: ${project.color}30;`}>/</span>
                      {project.tagline}
                    </div>
                    <h3 class="slide-name overflow-hidden mb-4">
                      <span class="slide-name-inner block font-display font-extrabold tracking-[-0.03em] leading-[0.9]"
                            style="font-size: clamp(2rem, 5vw, 4.5rem);">
                        {project.name}
                      </span>
                    </h3>
                    <div class="slide-divider h-[1px] w-full mb-5" style={`background: linear-gradient(to right, ${project.color}, transparent);`}></div>
                    <p class="slide-desc text-sm text-muted leading-relaxed mb-6">
                      {project.description}
                    </p>
                    <div class="slide-tags flex flex-wrap gap-2">
                      {project.tech.map((t) => (
                        <span class="font-mono text-[10px] px-3 py-1 border text-muted/70"
                              style={`border-color: ${project.color}30;`}>{t}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Counter (bottom right, tight to content) -->
          <div class="relative z-20 flex items-center justify-end pt-1">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5" id="project-pips">
                {projects.map((project, i) => (
                  <button
                    class="project-dot w-2 h-2 rounded-full cursor-pointer transition-all duration-400"
                    data-slide={i}
                    style={`background: ${i === 0 ? project.color : 'var(--color-border)'};`}
                  ></button>
                ))}
              </div>
              <span class="font-mono text-xs text-muted/40" id="project-counter">
                01 — {String(projects.length).padStart(2, '0')}
              </span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const allSlides = document.querySelectorAll<HTMLElement>('.project-slide');
  const dots = document.querySelectorAll<HTMLElement>('.project-dot');
  const counter = document.getElementById('project-counter');

  if (allSlides.length > 0) {
    let current = 0;
    let carouselAnimating = false;
    const total = allSlides.length;

    function getEls(i: number) {
      const s = allSlides[i];
      return {
        slide: s,
        img: s.querySelector('.slide-img') as HTMLElement,
        nameInner: s.querySelector('.slide-name-inner') as HTMLElement,
        tagline: s.querySelector('.slide-tagline') as HTMLElement,
        divider: s.querySelector('.slide-divider') as HTMLElement,
        desc: s.querySelector('.slide-desc') as HTMLElement,
        tags: s.querySelectorAll('.slide-tags span'),
      };
    }

    function updateIndicator() {
      dots.forEach((dot, i) => {
        const color = allSlides[i].dataset.color || '#7B61FF';
        dot.style.background = i === current ? color : 'var(--color-border)';
        dot.style.transform = i === current ? 'scale(1.4)' : 'scale(1)';
      });
      if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} — ${String(total).padStart(2, '0')}`;
    }

    function goToSlide(index: number) {
      if (carouselAnimating || index === current || index < 0 || index >= total) return;
      carouselAnimating = true;

      const dir = index > current ? 1 : -1;
      const cur = getEls(current);
      const nxt = getEls(index);

      const tl = gsap.timeline({
        defaults: { ease: "power3.inOut" },
        onComplete: () => {
          cur.slide.style.visibility = 'hidden';
          current = index;
          carouselAnimating = false;
          updateIndicator();
        }
      });

      // ── OUT ──
      tl.to(cur.img, { xPercent: -15 * dir, scale: 0.92, autoAlpha: 0, duration: 0.9 }, 0);
      tl.to(cur.nameInner, { yPercent: -120 * dir, duration: 0.7 }, 0);
      tl.to(cur.tagline, { y: -15 * dir, autoAlpha: 0, duration: 0.5 }, 0);
      tl.to(cur.divider, { scaleX: 0, transformOrigin: 'left', duration: 0.5 }, 0);
      tl.to(cur.desc, { y: -20 * dir, autoAlpha: 0, duration: 0.5 }, 0.1);
      tl.to(cur.tags, { y: -10 * dir, autoAlpha: 0, stagger: 0.02, duration: 0.4 }, 0.1);

      // ── IN ──
      gsap.set(nxt.slide, { visibility: 'visible' });
      gsap.set(nxt.img, { xPercent: 20 * dir, scale: 1.08, autoAlpha: 0 });
      gsap.set(nxt.nameInner, { yPercent: 120 * dir });
      gsap.set(nxt.tagline, { y: 25 * dir, autoAlpha: 0 });
      gsap.set(nxt.divider, { scaleX: 0, transformOrigin: 'left' });
      gsap.set(nxt.desc, { y: 30 * dir, autoAlpha: 0 });
      gsap.set(nxt.tags, { y: 15 * dir, autoAlpha: 0 });

      tl.to(nxt.img, { xPercent: 0, scale: 1, autoAlpha: 1, duration: 1, ease: "power2.out" }, 0.5);
      tl.to(nxt.nameInner, { yPercent: 0, duration: 0.9, ease: "power4.out" }, 0.6);
      tl.to(nxt.divider, { scaleX: 1, duration: 0.6, ease: "power2.out" }, 0.8);
      tl.to(nxt.tagline, { y: 0, autoAlpha: 1, duration: 0.6, ease: "power2.out" }, 0.7);
      tl.to(nxt.desc, { y: 0, autoAlpha: 1, duration: 0.7, ease: "power2.out" }, 0.85);
      tl.to(nxt.tags, { y: 0, autoAlpha: 1, stagger: 0.04, duration: 0.5, ease: "power2.out" }, 0.95);
    }

    updateIndicator();
    dots.forEach((dot, i) => dot.addEventListener('click', () => goToSlide(i)));

    (window as any).__carousel = {
      next: () => goToSlide(current + 1),
      prev: () => goToSlide(current - 1),
      isFirst: () => current === 0,
      isLast: () => current === total - 1,
      isAnimating: () => carouselAnimating,
    };
  }
</script>
