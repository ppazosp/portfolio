---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section class="panel" id="projects">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content">
          <div class="section-label">
            <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
          </div>

          <h2 class="panel-heading font-display text-2xl md:text-4xl font-bold tracking-tight mb-8 md:mb-10">
            {locale === 'es' ? 'Lo que he construido' : 'What I\'ve built'}
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
            {projects.map((project, i) => (
              <div class="border border-border p-5 md:p-6 bg-surface/30 group hover:border-muted/30 transition-colors"
                   style={`border-top: 2px solid ${project.color};`}>
                <div class="flex items-baseline justify-between mb-3">
                  <h3 class="font-display text-lg md:text-xl font-bold">{project.name}</h3>
                  <span class="font-mono text-[10px] text-muted/40">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <p class="font-mono text-[10px] uppercase tracking-[0.15em] mb-3" style={`color: ${project.color};`}>
                  {project.tagline}
                </p>
                <p class="text-xs text-muted leading-relaxed mb-4 line-clamp-3">
                  {project.description}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.slice(0, 3).map((t) => (
                    <span class="font-mono text-[9px] px-2 py-0.5 border border-border text-muted/60">{t}</span>
                  ))}
                  {project.tech.length > 3 && (
                    <span class="font-mono text-[9px] px-2 py-0.5 text-muted/40">+{project.tech.length - 3}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
