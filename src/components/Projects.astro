---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section class="panel" id="projects">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content relative h-full flex flex-col">

          <!-- Section header -->
          <div class="section-label mb-2 md:mb-3 relative z-20">
            <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
          </div>

          <!-- Slides area -->
          <div class="relative flex-1 min-h-0 max-h-[80vh] md:max-h-[75vh]">
            {projects.map((project, i) => (
              <div
                class="project-slide absolute top-0 left-0 w-full h-full flex items-center pt-1 md:pt-0"
                data-slide={i}
                style={i > 0 ? 'visibility: hidden;' : ''}
              >
                <div class="relative w-full">

                  <!-- Giant watermark number -->
                  <span class="proj-watermark absolute select-none pointer-events-none font-display font-extrabold"
                        style={`font-size: clamp(12rem, 35vw, 28rem); line-height: 0.8; top: 50%; right: -2%; transform: translateY(-55%); color: transparent; -webkit-text-stroke: 1px color-mix(in srgb, var(--color-accent) 12%, transparent);`}>
                    {String(i + 1).padStart(2, '0')}
                  </span>

                  <!-- Tagline row -->
                  <div class="proj-tagline font-mono text-[10px] md:text-xs uppercase tracking-[0.2em] mb-3 md:mb-5 flex items-center gap-3">
                    <span class="text-accent font-bold">{String(i + 1).padStart(2, '0')}</span>
                    <span class="h-px flex-1 max-w-12 bg-accent/30"></span>
                    <span class="text-accent/70">{project.tagline}</span>
                  </div>

                  <!-- Top accent line -->
                  <div class="proj-line-top h-px w-full mb-3 md:mb-5" style="background: linear-gradient(to right, var(--color-accent), var(--color-accent) 30%, transparent);"></div>

                  <!-- Massive project name -->
                  <div class="proj-name-wrap overflow-hidden mb-3 md:mb-5">
                    <h3 class="proj-name-inner font-display font-extrabold tracking-[-0.04em] leading-[0.85] text-foreground"
                        style="font-size: clamp(3rem, 11vw, 9rem);">
                      {project.name}
                    </h3>
                  </div>

                  <!-- Bottom accent line -->
                  <div class="proj-line-bot h-px w-full mb-4 md:mb-8" style="background: linear-gradient(to right, var(--color-accent) 60%, transparent);"></div>

                  <!-- Description + Tags grid -->
                  <div class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-8">
                    <!-- Description with vertical accent + solo stamp -->
                    <div class="md:col-span-7 relative pl-4 md:pl-6">
                      <div class="proj-accent-bar absolute left-0 top-0 w-px h-full origin-top" style="background: linear-gradient(to bottom, var(--color-accent), transparent);"></div>
                      <p class="proj-desc text-xs md:text-base text-muted leading-relaxed line-clamp-4 md:line-clamp-none">
                        {project.description}
                      </p>
                      <!-- Solo stamp -->
                      <div class="proj-solo mt-3 md:mt-5 flex items-center gap-2.5">
                        <div class="solo-line h-px w-4 bg-accent"></div>
                        <span class="font-mono text-[10px] md:text-xs uppercase tracking-[0.3em] text-accent font-medium">
                          {locale === 'es' ? 'Construido en solitario' : 'Built entirely solo'}
                        </span>
                      </div>
                    </div>

                    <!-- Tech tags -->
                    <div class="md:col-span-4 md:col-start-9 flex flex-col gap-1.5 md:gap-2">
                      <span class="proj-tags-label font-mono text-[9px] md:text-[10px] uppercase tracking-[0.25em] text-accent/50 mb-1">{locale === 'es' ? 'Stack' : 'Stack'}</span>
                      <div class="flex flex-wrap md:flex-col gap-1.5 md:gap-2">
                        {project.tech.map((t) => (
                          <span class="proj-tag font-mono text-[10px] md:text-xs px-2.5 py-0.5 md:px-3 md:py-1 border border-accent/20 text-muted/70 hover:border-accent/50 hover:text-foreground/80 transition-colors duration-300 w-fit">{t}</span>
                        ))}
                      </div>
                    </div>
                  </div>

                </div>
              </div>
            ))}
          </div>

          <!-- Counter (bottom right) -->
          <div class="relative z-20 flex items-center justify-end pt-1">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5" id="project-pips">
                {projects.map((_, i) => (
                  <button
                    class={`project-dot w-2 h-2 rounded-full cursor-pointer transition-all duration-400 ${i === 0 ? 'active' : ''}`}
                    data-slide={i}
                  ></button>
                ))}
              </div>
              <span class="font-mono text-xs text-muted/40" id="project-counter">
                01 — {String(projects.length).padStart(2, '0')}
              </span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const allSlides = document.querySelectorAll<HTMLElement>('.project-slide');
  const dots = document.querySelectorAll<HTMLElement>('.project-dot');
  const counter = document.getElementById('project-counter');

  if (allSlides.length > 0) {
    let current = 0;
    let carouselAnimating = false;
    const total = allSlides.length;

    function getEls(i: number) {
      const s = allSlides[i];
      return {
        slide: s,
        watermark: s.querySelector('.proj-watermark') as HTMLElement,
        tagline: s.querySelector('.proj-tagline') as HTMLElement,
        lineTop: s.querySelector('.proj-line-top') as HTMLElement,
        nameInner: s.querySelector('.proj-name-inner') as HTMLElement,
        lineBot: s.querySelector('.proj-line-bot') as HTMLElement,
        accentBar: s.querySelector('.proj-accent-bar') as HTMLElement,
        desc: s.querySelector('.proj-desc') as HTMLElement,
        solo: s.querySelector('.proj-solo') as HTMLElement,
        tagsLabel: s.querySelector('.proj-tags-label') as HTMLElement,
        tags: s.querySelectorAll('.proj-tag'),
      };
    }

    function updateIndicator() {
      dots.forEach((dot, i) => dot.classList.toggle('active', i === current));
      if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} — ${String(total).padStart(2, '0')}`;
    }

    function updateIndicatorTo(idx: number) {
      dots.forEach((dot, i) => dot.classList.toggle('active', i === idx));
      if (counter) counter.textContent = `${String(idx + 1).padStart(2, '0')} — ${String(total).padStart(2, '0')}`;
    }

    function goToSlide(index: number) {
      if (carouselAnimating || index === current || index < 0 || index >= total) return;
      carouselAnimating = true;

      const dir = index > current ? 1 : -1;
      const cur = getEls(current);
      const nxt = getEls(index);

      updateIndicatorTo(index);

      const tl = gsap.timeline({
        defaults: { ease: "power3.inOut" },
        onComplete: () => {
          cur.slide.style.visibility = 'hidden';
          current = index;
          carouselAnimating = false;
        }
      });

      // ── OUT ──
      tl.to(cur.watermark, { autoAlpha: 0, scale: 0.9, duration: 0.6 }, 0);
      tl.to(cur.tagline, { y: -20 * dir, autoAlpha: 0, duration: 0.4 }, 0);
      tl.to(cur.lineTop, { scaleX: 0, transformOrigin: 'right', duration: 0.5 }, 0);
      tl.to(cur.nameInner, { yPercent: -120 * dir, duration: 0.7 }, 0.05);
      tl.to(cur.lineBot, { scaleX: 0, transformOrigin: 'left', duration: 0.5 }, 0.1);
      tl.to(cur.accentBar, { scaleY: 0, transformOrigin: 'top', duration: 0.4 }, 0.1);
      tl.to(cur.desc, { y: -20 * dir, autoAlpha: 0, duration: 0.4 }, 0.1);
      tl.to(cur.solo.querySelector('.solo-line'), { scaleX: 0, transformOrigin: 'right', duration: 0.3 }, 0.12);
      tl.to(cur.solo.querySelector('span'), { x: -10, autoAlpha: 0, duration: 0.3 }, 0.15);
      tl.to(cur.tagsLabel, { autoAlpha: 0, duration: 0.3 }, 0.1);
      tl.to(cur.tags, { y: -10 * dir, autoAlpha: 0, stagger: 0.02, duration: 0.3 }, 0.15);

      // ── IN ──
      gsap.set(nxt.slide, { visibility: 'visible' });
      gsap.set(nxt.watermark, { autoAlpha: 0, scale: 1.1 });
      gsap.set(nxt.tagline, { y: 25 * dir, autoAlpha: 0 });
      gsap.set(nxt.lineTop, { scaleX: 0, transformOrigin: 'left' });
      gsap.set(nxt.nameInner, { yPercent: 120 * dir });
      gsap.set(nxt.lineBot, { scaleX: 0, transformOrigin: 'left' });
      gsap.set(nxt.accentBar, { scaleY: 0, transformOrigin: 'top' });
      gsap.set(nxt.desc, { y: 30 * dir, autoAlpha: 0 });
      gsap.set(nxt.solo.querySelector('.solo-line'), { scaleX: 0, transformOrigin: 'left' });
      gsap.set(nxt.solo.querySelector('span'), { x: 15, autoAlpha: 0 });
      gsap.set(nxt.tagsLabel, { autoAlpha: 0 });
      gsap.set(nxt.tags, { y: 15 * dir, autoAlpha: 0 });

      tl.to(nxt.watermark, { autoAlpha: 1, scale: 1, duration: 1.2, ease: "power2.out" }, 0.4);
      tl.to(nxt.tagline, { y: 0, autoAlpha: 1, duration: 0.6, ease: "power2.out" }, 0.55);
      tl.to(nxt.lineTop, { scaleX: 1, duration: 0.7, ease: "power2.out" }, 0.6);
      tl.to(nxt.nameInner, { yPercent: 0, duration: 0.9, ease: "power4.out" }, 0.55);
      tl.to(nxt.lineBot, { scaleX: 1, duration: 0.7, ease: "power2.out" }, 0.7);
      tl.to(nxt.accentBar, { scaleY: 1, duration: 0.8, ease: "power2.out" }, 0.75);
      tl.to(nxt.desc, { y: 0, autoAlpha: 1, duration: 0.7, ease: "power2.out" }, 0.8);
      tl.to(nxt.solo.querySelector('.solo-line'), { scaleX: 1, duration: 0.5, ease: "power3.out" }, 0.92);
      tl.to(nxt.solo.querySelector('span'), { x: 0, autoAlpha: 1, duration: 0.5, ease: "power3.out" }, 1.0);
      tl.to(nxt.tagsLabel, { autoAlpha: 1, duration: 0.5, ease: "power2.out" }, 0.8);
      tl.to(nxt.tags, { y: 0, autoAlpha: 1, stagger: 0.05, duration: 0.5, ease: "power2.out" }, 0.85);
    }

    updateIndicator();
    dots.forEach((dot, i) => dot.addEventListener('click', () => goToSlide(i)));

    (window as any).__carousel = {
      next: () => goToSlide(current + 1),
      prev: () => goToSlide(current - 1),
      isFirst: () => current === 0,
      isLast: () => current === total - 1,
      isAnimating: () => carouselAnimating,
    };
  }
</script>
