---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { projects } = portfolioConfig;
---

<section class="panel" id="projects">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content flex flex-col justify-center">
          <div class="section-label">
            <span>{locale === 'es' ? 'Proyectos' : 'Projects'}</span>
          </div>

          <!-- Carousel -->
          <div class="relative overflow-hidden" id="carousel">
            <div class="carousel-track flex transition-none" id="carousel-track">
              {projects.map((project, i) => (
                <div class="carousel-slide flex-shrink-0 w-full" data-index={i}>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 items-center">
                    <!-- Image placeholder -->
                    <div class="carousel-image relative h-48 md:h-80 overflow-hidden border border-border"
                         style={`background: linear-gradient(135deg, ${project.color}18 0%, ${project.color}06 50%, transparent 100%);`}>
                      <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-display font-extrabold select-none pointer-events-none"
                            style={`font-size: clamp(8rem, 20vw, 16rem); color: ${project.color}; opacity: 0.07; line-height: 1;`}>
                        {project.name.charAt(0)}
                      </span>
                      <div class="absolute inset-0 opacity-30"
                           style={`background-image: radial-gradient(circle, ${project.color}20 1px, transparent 1px); background-size: 24px 24px;`}></div>
                      <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${project.color};`}></div>
                      <!-- Slide number -->
                      <div class="absolute bottom-4 right-4 font-mono text-xs text-muted/30">
                        {String(i + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}
                      </div>
                    </div>

                    <!-- Info -->
                    <div>
                      <span class="font-mono text-[10px] text-muted/40 mb-2 block">{String(i + 1).padStart(2, '0')}</span>
                      <h3 class="font-display text-3xl md:text-5xl font-bold mb-2 tracking-tight">{project.name}</h3>
                      <p class="font-mono text-xs uppercase tracking-[0.15em] mb-4" style={`color: ${project.color};`}>{project.tagline}</p>
                      <p class="text-sm text-muted leading-relaxed mb-6">{project.description}</p>
                      <div class="flex flex-wrap gap-2">
                        {project.tech.map((t) => (
                          <span class="font-mono text-[10px] px-3 py-1 border border-border text-muted/60">{t}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Controls -->
            <div class="flex items-center justify-between mt-8">
              <button id="carousel-prev" class="font-mono text-xs text-muted hover:text-accent transition-colors px-3 py-2 border border-border hover:border-accent/40 cursor-pointer">
                &larr; {locale === 'es' ? 'Anterior' : 'Prev'}
              </button>

              <div class="flex gap-2" id="carousel-dots">
                {projects.map((_, i) => (
                  <button class="carousel-dot w-8 h-1 bg-border cursor-pointer transition-all duration-300" data-slide={i}></button>
                ))}
              </div>

              <button id="carousel-next" class="font-mono text-xs text-muted hover:text-accent transition-colors px-3 py-2 border border-border hover:border-accent/40 cursor-pointer">
                {locale === 'es' ? 'Siguiente' : 'Next'} &rarr;
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const track = document.getElementById('carousel-track') as HTMLElement;
  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');

  if (track && slides.length > 0) {
    let current = 0;
    let animating = false;
    const total = slides.length;

    function updateDots() {
      dots.forEach((dot, i) => {
        if (i === current) {
          dot.classList.add('!bg-accent', '!w-12');
        } else {
          dot.classList.remove('!bg-accent', '!w-12');
        }
      });
    }

    function goToSlide(index: number) {
      if (animating || index === current) return;
      animating = true;

      const direction = index > current ? 1 : -1;

      const tl = gsap.timeline({
        onComplete: () => { animating = false; }
      });

      // Current slide exits
      const currentSlide = slides[current];
      const currentImg = currentSlide.querySelector('.carousel-image');
      const currentInfo = currentSlide.querySelector('div:last-child');

      tl.to(currentImg, {
        xPercent: -30 * direction,
        scale: 0.9,
        autoAlpha: 0,
        duration: 0.5,
        ease: "power2.in"
      }, 0);

      if (currentInfo) {
        tl.to(currentInfo.children, {
          y: -20 * direction,
          autoAlpha: 0,
          stagger: 0.02,
          duration: 0.3,
          ease: "power2.in"
        }, 0);
      }

      // Move track
      tl.to(track, {
        xPercent: -index * 100,
        duration: 0.7,
        ease: "power3.inOut",
      }, 0.2);

      // New slide enters
      const newSlide = slides[index];
      const newImg = newSlide.querySelector('.carousel-image');
      const newInfo = newSlide.querySelector('div:last-child');

      tl.fromTo(newImg,
        { xPercent: 30 * direction, scale: 1.1, autoAlpha: 0 },
        { xPercent: 0, scale: 1, autoAlpha: 1, duration: 0.6, ease: "power2.out" },
        0.4
      );

      if (newInfo) {
        tl.fromTo(newInfo.children,
          { y: 40 * direction, autoAlpha: 0 },
          { y: 0, autoAlpha: 1, stagger: 0.04, duration: 0.5, ease: "power3.out" },
          0.5
        );
      }

      current = index;
      updateDots();
    }

    // Init
    gsap.set(track, { xPercent: 0 });
    updateDots();

    prevBtn?.addEventListener('click', () => goToSlide((current - 1 + total) % total));
    nextBtn?.addEventListener('click', () => goToSlide((current + 1) % total));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goToSlide(i)));

    // Expose carousel API for the panel Observer
    (window as any).__carousel = {
      next: () => goToSlide(current + 1),
      prev: () => goToSlide(current - 1),
      isFirst: () => current === 0,
      isLast: () => current === total - 1,
    };
  }
</script>
