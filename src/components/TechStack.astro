---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const marqueeRows = [
  {
    items: ["Python", "TypeScript", "JavaScript", "Go", "Rust", "C++", "Java", "Swift", "Kotlin", "Ruby", "PHP", "Elixir", "Scala", "Dart"],
    speed: 60,
    direction: "left",
    accent: false
  },
  {
    items: ["React", "Next.js", "Vue", "Nuxt", "Svelte", "Astro", "Angular", "Tailwind", "Three.js", "GSAP", "Framer Motion", "D3.js", "WebGL", "CSS"],
    speed: 45,
    direction: "right",
    accent: false
  },
  {
    items: ["Node.js", "FastAPI", "Django", "Express", "PostgreSQL", "MongoDB", "Redis", "Docker", "Kubernetes", "AWS", "GCP", "Supabase", "Firebase", "Nginx"],
    speed: 55,
    direction: "left",
    accent: false
  },
  {
    items: ["LLM APIs", "Vector DBs", "RAG Pipelines", "Multi-Agent", "Claude", "GPT", "Gemini", "OSS Models", "Embeddings", "ReRankers", "Audio AI", "Computer Vision", "Prompt Eng.", "MCP"],
    speed: 35,
    direction: "right",
    accent: true
  }
];
---

<section class="panel" id="stack">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content h-full flex flex-col">
          <div class="section-label mb-3">
            <span>Stack</span>
          </div>

          <div class="flex-1 relative overflow-hidden" id="stack-container">

            <!-- Marquee rows distributed vertically -->
            <div class="absolute inset-0 flex flex-col justify-between py-4 md:py-10">
              {marqueeRows.map((row) => (
                <div class="stack-row overflow-hidden" data-speed={row.speed} data-direction={row.direction}>
                  <div class="stack-row-inner flex items-center whitespace-nowrap will-change-transform">
                    {[0, 1].map(() =>
                      row.items.map((item) => (
                        <span class="inline-flex items-center">
                          <span
                            class="font-mono text-sm md:text-xl tracking-wide px-3 md:px-5 select-none"
                            style={row.accent
                              ? "color: var(--color-accent); opacity: 0.3;"
                              : "color: var(--color-foreground); opacity: 0.07;"}
                          >
                            {item}
                          </span>
                          <span
                            class="select-none"
                            style={row.accent
                              ? "color: var(--color-accent); opacity: 0.12;"
                              : "color: var(--color-foreground); opacity: 0.04;"}
                          >·</span>
                        </span>
                      ))
                    )}
                  </div>
                </div>
              ))}
            </div>

            <!-- Center vignette + statement -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="relative text-center">
                <div class="absolute -inset-24 md:-inset-40" style="background: radial-gradient(ellipse 55% 50% at center, var(--color-background) 30%, transparent 75%);"></div>
                <div class="relative">
                  <h2
                    class="panel-heading font-display font-extrabold tracking-[-0.04em] leading-[0.85]"
                    style="font-size: clamp(3.5rem, 12vw, 9rem);"
                  >
                    {locale === 'es' ? 'SIN' : 'NO'}<br/>
                    <span style="color: var(--color-accent);">{locale === 'es' ? 'LÍMITES' : 'LIMITS'}</span>
                  </h2>
                  <div class="flex items-center justify-center gap-3 mt-5 md:mt-7">
                    <div class="h-px w-8 md:w-12" style="background: var(--color-accent); opacity: 0.4;"></div>
                    <div class="w-1.5 h-1.5 rounded-full" style="background: var(--color-accent); opacity: 0.6;"></div>
                    <div class="h-px w-8 md:w-12" style="background: var(--color-accent); opacity: 0.4;"></div>
                  </div>
                  <p class="font-mono text-[9px] md:text-[11px] uppercase tracking-[0.2em] mt-4 md:mt-5" style="color: var(--color-muted); opacity: 0.6;">
                    {locale === 'es' ? 'orquestando agentes IA con cualquier stack' : 'orchestrating ai agents across any stack'}
                  </p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const container = document.getElementById('stack-container');
  const rows = document.querySelectorAll<HTMLElement>('.stack-row');

  if (container && rows.length > 0) {
    // Set initial state: rows invisible
    gsap.set(rows, { autoAlpha: 0 });

    rows.forEach(row => {
      const inner = row.querySelector('.stack-row-inner') as HTMLElement;
      if (!inner) return;

      const speed = Number(row.dataset.speed) || 40;
      const direction = row.dataset.direction;

      // For right-moving rows, start offset so the loop is seamless
      if (direction === 'right') {
        gsap.set(inner, { xPercent: -50 });
      }

      gsap.to(inner, {
        xPercent: direction === 'right' ? 0 : -50,
        duration: speed,
        ease: "none",
        repeat: -1,
      });
    });

    // Entrance: fade in rows with stagger when panel becomes visible
    const panel = document.getElementById('stack');
    if (panel) {
      const observer = new MutationObserver(() => {
        if (panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
          revealRows();
          observer.disconnect();
        }
      });
      observer.observe(panel, { attributes: true, attributeFilter: ['style'] });

      // Edge case: already visible
      if (panel.style.visibility !== 'hidden' && panel.style.visibility !== '') {
        setTimeout(revealRows, 600);
      }
    }

    let revealed = false;
    function revealRows() {
      if (revealed) return;
      revealed = true;
      gsap.to(rows, {
        autoAlpha: 1,
        duration: 1.2,
        stagger: 0.15,
        ease: "power2.out",
        delay: 0.4
      });
    }

    // Subtle speed boost on hover (scoped to marquee tweens only)
    const marqueTweens: gsap.core.Tween[] = [];
    rows.forEach(row => {
      const inner = row.querySelector('.stack-row-inner') as HTMLElement;
      if (inner) {
        const tween = gsap.getTweensOf(inner)[0];
        if (tween) marqueTweens.push(tween);
      }
    });
    container.addEventListener('mouseenter', () => {
      marqueTweens.forEach(t => gsap.to(t, { timeScale: 1.8, duration: 0.6 }));
    });
    container.addEventListener('mouseleave', () => {
      marqueTweens.forEach(t => gsap.to(t, { timeScale: 1, duration: 0.8 }));
    });
  }
</script>
