---
import { getPortfolioConfig, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const portfolioConfig = getPortfolioConfig(locale);
const { techStack } = portfolioConfig;
---

<section class="panel" id="stack">
  <div class="panel-outer">
    <div class="panel-inner">
      <div class="panel-bg">
        <div class="panel-content">
          <div class="section-label">
            <span>Stack</span>
          </div>

          <h2 class="panel-heading font-display text-2xl md:text-4xl font-bold tracking-tight mb-8 md:mb-12">
            {locale === 'es' ? 'Tecnologias' : 'Technologies'}
          </h2>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-10">
            {techStack.map((group) => (
              <div>
                <h3 class="font-mono text-[10px] md:text-xs text-accent uppercase tracking-[0.2em] mb-4 pb-2 border-b border-border">
                  {group.category}
                </h3>
                <div class="space-y-0">
                  {group.items.map((item) => (
                    <div class="flex items-center gap-2 py-2 border-b border-border/30 group cursor-default">
                      <div class="w-1 h-1 rounded-full bg-muted/30 group-hover:bg-accent transition-colors flex-shrink-0"></div>
                      <span class="text-sm text-foreground/70 group-hover:text-foreground transition-colors">{item}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
