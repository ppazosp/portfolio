---
import '../styles/global.css';
import { getPortfolioConfig, getLocaleFromUrl, type Locale } from '../lib/i18n';
import Header from '../components/Header.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  locale?: Locale;
}

const currentUrl = new URL(Astro.request.url);
const locale = Astro.props.locale || getLocaleFromUrl(currentUrl);
const portfolioConfig = getPortfolioConfig(locale);

const {
  title,
  description = portfolioConfig.seo.description,
  image = portfolioConfig.seo.ogImage,
  type = 'website',
  canonical,
} = Astro.props;

const canonicalUrl = canonical || currentUrl.href;

const basePathname = currentUrl.pathname.replace(/^\/es/, '') || '/';
const alternateUrls = {
  en: `${Astro.site}${basePathname}`,
  es: `${Astro.site}/es${basePathname === '/' ? '' : basePathname}`
};
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang="en" href={alternateUrls.en} />
    <link rel="alternate" hreflang="es" href={alternateUrls.es} />
    <link rel="alternate" hreflang="x-default" href={alternateUrls.en} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, currentUrl).href} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={portfolioConfig.seo.siteName} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, currentUrl).href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=JetBrains+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-foreground antialiased">
    <!-- Page Loader -->
    <div class="page-loader" id="page-loader">
      <span class="font-display text-3xl font-bold text-accent" id="loader-text">PP</span>
      <div class="loader-bar" id="loader-bar"></div>
    </div>

    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-background focus:rounded">
      Skip to main content
    </a>

    <Header locale={locale} />

    <main id="main">
      <slot />
    </main>

    <footer class="border-t border-border py-6">
      <div class="max-w-[1400px] mx-auto px-6 md:px-12">
        <div class="flex items-center justify-between">
          <span class="font-mono text-xs text-muted">
            {portfolioConfig.footer.location}
          </span>
          <a
            href={portfolioConfig.footer.sourceCode.url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs text-muted hover:text-accent transition-colors"
          >
            {portfolioConfig.footer.sourceCode.text}
          </a>
        </div>
      </div>
    </footer>

    <!-- Page loader animation -->
    <script>
      import gsap from 'gsap';

      const loader = document.getElementById('page-loader');
      const loaderBar = document.getElementById('loader-bar');
      const loaderText = document.getElementById('loader-text');

      if (loader && loaderBar && loaderText) {
        const tl = gsap.timeline();

        tl.to(loaderBar, {
          width: '100%',
          duration: 0.8,
          ease: "power2.inOut"
        })
        .to(loaderText, {
          scale: 1.2,
          duration: 0.3,
          ease: "power2.in"
        }, 0.4)
        .to(loaderText, {
          autoAlpha: 0,
          scale: 0.8,
          duration: 0.3,
          ease: "power2.in"
        })
        .to(loader, {
          yPercent: -100,
          duration: 0.7,
          ease: "power3.inOut"
        })
        .set(loader, { display: 'none' });
      }
    </script>
  </body>
</html>
